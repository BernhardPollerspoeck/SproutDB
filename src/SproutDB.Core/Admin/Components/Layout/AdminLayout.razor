@inherits LayoutComponentBase
@implements IDisposable

@{
    var currentPath = NavigationManager.Uri;
    bool IsActive(string page) => currentPath.Contains(page, StringComparison.OrdinalIgnoreCase);
    bool IsQuery = !IsActive("/schema") && !IsActive("/monitoring") && !IsActive("/settings");
    int totalTables = databases.Sum(d => d.Tables.Count);
}

<!-- Topbar -->
<div class="topbar">
    <a class="logo" href="/sproutdb/admin">
        <div class="logo-icon">&#127793;</div>
        <span>Sprout</span>DB
    </a>
    <div class="topbar-nav">
        <a href="/sproutdb/admin" class="@(IsQuery ? "active" : "")">Query</a>
        <a href="/sproutdb/admin/schema" class="@(IsActive("/schema") ? "active" : "")">Schema</a>
        <a href="/sproutdb/admin/monitoring" class="@(IsActive("/monitoring") ? "active" : "")">Monitoring</a>
        <a href="/sproutdb/admin/settings" class="@(IsActive("/settings") ? "active" : "")">Admin</a>
    </div>
    <div class="topbar-right">
        <div class="status-dot"></div>
        <span class="topbar-info">@databases.Count db · @totalTables tables</span>
        <button class="theme-toggle" @onclick="ToggleTheme">@(_theme == "dark" ? "\u2600" : "\u263e")</button>
    </div>
</div>

<div class="main">
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-header">
            <span class="sidebar-title">Databases</span>
            <button class="sidebar-action" @onclick="StartCreateDb">+</button>
        </div>
        <div class="sidebar-search">
            <span class="sidebar-search-icon">&#8981;</span>
            <input type="text" placeholder="Filter tables..." @bind="filterText" @bind:event="oninput" />
        </div>
        <div class="sidebar-tree">
            @if (_showCreateDb)
            {
                <div class="tree-item">
                    <span class="tree-icon db">&#9670;</span>
                    <input @ref="_createDbInputRef"
                           class="create-db-input"
                           type="text"
                           placeholder="database name"
                           @bind="_newDbName"
                           @bind:event="oninput"
                           @onkeyup="HandleCreateDbKey"
                           @onblur="CancelCreateDb" />
                </div>
                @if (_createDbError is not null)
                {
                    <div class="create-db-error">@_createDbError</div>
                }
            }
            @if (databases.Count == 0 && !_showCreateDb)
            {
                <div class="tree-item">
                    <span class="tree-chevron">&#9654;</span>
                    <span class="tree-icon db">&#9670;</span>
                    <span style="color: var(--text-3); font-style: italic; font-size: 11.5px;">No databases loaded</span>
                </div>
            }
            else
            {
                @foreach (var db in sortedDatabases)
                {
                    var filteredTables = string.IsNullOrEmpty(filterText)
                        ? db.Tables
                        : db.Tables.Where(t => t.Contains(filterText, StringComparison.OrdinalIgnoreCase)).ToList();

                    <div class="tree-item @(db.Expanded ? "expanded" : "")" @onclick="() => ToggleDb(db)" style="cursor: pointer;">
                        <span class="tree-chevron">&#9654;</span>
                        <span class="tree-icon db">&#9670;</span>
                        <span>@db.Name</span>
                        @if (db.Tables.Count > 0)
                        {
                            <span class="tree-badge">@db.Tables.Count</span>
                        }
                    </div>
                    @if (db.Expanded && filteredTables.Count > 0)
                    {
                        <div class="tree-children">
                            @foreach (var table in filteredTables)
                            {
                                <div class="tree-item" @onclick="() => NavigateToTable(db.Name, table)" style="cursor: pointer;">
                                    <span class="tree-icon table">&#9632;</span>
                                    <span>@table</span>
                                </div>
                            }
                        </div>
                    }
                }
            }
        </div>
    </div>

    <!-- Content -->
    <div class="content">
        @Body
    </div>

    <!-- Right Panel -->
    <div class="right-panel">
        <div class="panel-section">
            <div class="panel-section-title">Live Metrics <span class="live-dot"></span></div>
            <div class="metrics-grid">
                <div class="metric-card">
                    <div class="metric-value green">@FormatOpsPerSec(_writesPerSec)</div>
                    <div class="metric-label">Writes/s</div>
                </div>
                <div class="metric-card">
                    <div class="metric-value blue">@FormatOpsPerSec(_readsPerSec)</div>
                    <div class="metric-label">Reads/s</div>
                </div>
                <div class="metric-card">
                    <div class="metric-value">@FormatSize(_storageSizeBytes)</div>
                    <div class="metric-label">Storage</div>
                </div>
                <div class="metric-card">
                    <div class="metric-value orange">@FormatSize(_walSizeBytes)</div>
                    <div class="metric-label">WAL</div>
                </div>
            </div>
        </div>
        <div class="panel-section">
            <div class="panel-section-title">Auto-Index</div>
            <div style="font-size: 11.5px; color: var(--text-3); font-style: italic;">No indexes</div>
        </div>
        <div class="panel-section" style="border-bottom: none; padding-bottom: 6px;">
            <div class="panel-section-title">Activity <span class="live-dot"></span></div>
        </div>
        <div class="activity-feed">
            @if (_activityItems.Count == 0)
            {
                <div style="font-size: 11.5px; color: var(--text-3); font-style: italic; padding: 8px 0;">No activity yet</div>
            }
            else
            {
                @foreach (var item in _activityItems)
                {
                    <div class="activity-item">
                        <div class="activity-dot @item.DotClass"></div>
                        <div class="activity-text"><strong>@item.Label</strong> @item.Target</div>
                        <div class="activity-time">@FormatRelativeTime(item.Timestamp)</div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    [Inject]
    private SproutEngine Engine { get; set; } = default!;

    [Inject]
    private IJSRuntime JS { get; set; } = default!;

    private List<DbNode> databases = new();
    private string filterText = string.Empty;

    // Theme toggle
    private string _theme = "dark";

    // Create database
    private bool _showCreateDb;
    private string _newDbName = string.Empty;
    private string? _createDbError;
    private ElementReference _createDbInputRef;
    private bool _shouldFocusCreateDb;

    // Activity feed
    private IDisposable? _activitySubscription;
    private readonly LinkedList<ActivityItem> _activityItems = new();
    private const int MaxActivityItems = 50;

    // Live metrics state
    private System.Threading.Timer? _refreshTimer;
    private long _prevReads;
    private long _prevWrites;
    private double _readsPerSec;
    private double _writesPerSec;
    private long _storageSizeBytes;
    private long _walSizeBytes;

    private IEnumerable<DbNode> sortedDatabases =>
        databases.OrderByDescending(d => d.Name.StartsWith('_')).ThenBy(d => d.Name);

    protected override void OnInitialized()
    {
        RefreshDatabases();

        // Initial metrics snapshot
        var metrics = Engine.GetMetrics();
        _prevReads = metrics.TotalReads;
        _prevWrites = metrics.TotalWrites;
        _storageSizeBytes = metrics.StorageSizeBytes;
        _walSizeBytes = metrics.WalSizeBytes;

        _refreshTimer = new System.Threading.Timer(RefreshMetrics, null, 2000, 2000);

        _activitySubscription = Engine.ChangeNotifier.SubscribeAll(OnActivity);
    }

    private void RefreshMetrics(object? state)
    {
        var metrics = Engine.GetMetrics();

        _readsPerSec = (metrics.TotalReads - _prevReads) / 2.0;
        _writesPerSec = (metrics.TotalWrites - _prevWrites) / 2.0;
        _prevReads = metrics.TotalReads;
        _prevWrites = metrics.TotalWrites;
        _storageSizeBytes = metrics.StorageSizeBytes;
        _walSizeBytes = metrics.WalSizeBytes;

        InvokeAsync(StateHasChanged);
    }

    private static string FormatOpsPerSec(double ops)
    {
        if (ops < 0.1) return "0";
        if (ops >= 1000) return $"{ops / 1000:F1}k";
        return ops >= 10 ? $"{ops:F0}" : $"{ops:F1}";
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024 * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):F1} GB";
    }

    private void OnActivity(string database, string table, SproutResponse response)
    {
        // Filter out _schema pseudo-table events and errors
        if (table == "_schema" || response.Operation == SproutOperation.Error)
            return;

        var item = new ActivityItem
        {
            Label = response.Operation.ToString().ToUpperInvariant(),
            Target = $"{database}.{table}",
            DotClass = GetActivityDotClass(response.Operation),
            Timestamp = DateTime.UtcNow,
        };

        lock (_activityItems)
        {
            _activityItems.AddFirst(item);
            while (_activityItems.Count > MaxActivityItems)
                _activityItems.RemoveLast();
        }

        InvokeAsync(StateHasChanged);
    }

    private static string GetActivityDotClass(SproutOperation op) => op switch
    {
        SproutOperation.Upsert => "insert",
        SproutOperation.Delete or SproutOperation.PurgeTable or SproutOperation.PurgeDatabase or SproutOperation.PurgeColumn => "delete",
        SproutOperation.CreateTable or SproutOperation.AddColumn or SproutOperation.RenameColumn or SproutOperation.AlterColumn => "update",
        _ => "query",
    };

    private static string FormatRelativeTime(DateTime utcTimestamp)
    {
        var elapsed = DateTime.UtcNow - utcTimestamp;
        if (elapsed.TotalSeconds < 60) return $"{Math.Max(1, (int)elapsed.TotalSeconds)}s";
        if (elapsed.TotalMinutes < 60) return $"{(int)elapsed.TotalMinutes}m";
        if (elapsed.TotalHours < 24) return $"{(int)elapsed.TotalHours}h";
        return $"{(int)elapsed.TotalDays}d";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _theme = await JS.InvokeAsync<string>("sproutAdmin.getTheme");
            StateHasChanged();
        }

        if (_shouldFocusCreateDb)
        {
            _shouldFocusCreateDb = false;
            try { await _createDbInputRef.FocusAsync(); } catch { }
        }
    }

    private async Task ToggleTheme()
    {
        _theme = _theme == "dark" ? "light" : "dark";
        await JS.InvokeVoidAsync("sproutAdmin.setTheme", _theme);
    }

    // ── Create Database ──

    private void StartCreateDb()
    {
        _showCreateDb = true;
        _newDbName = string.Empty;
        _createDbError = null;
        _shouldFocusCreateDb = true;
    }

    private void CancelCreateDb()
    {
        _showCreateDb = false;
        _newDbName = string.Empty;
        _createDbError = null;
    }

    private void HandleCreateDbKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            SubmitCreateDb();
        }
        else if (e.Key == "Escape")
        {
            CancelCreateDb();
        }
    }

    private void SubmitCreateDb()
    {
        var name = _newDbName.Trim();
        if (string.IsNullOrEmpty(name))
        {
            _createDbError = "Name cannot be empty";
            return;
        }

        var response = Engine.Execute("create database", name);
        if (response.Operation == SproutOperation.Error)
        {
            _createDbError = response.Errors?.FirstOrDefault()?.Message ?? "Failed to create database";
            return;
        }

        _showCreateDb = false;
        _newDbName = string.Empty;
        _createDbError = null;

        RefreshDatabases();

        // Auto-expand the new database
        var newDb = databases.FirstOrDefault(d => d.Name.Equals(name, StringComparison.OrdinalIgnoreCase));
        if (newDb is not null)
            newDb.Expanded = true;

        // Navigate to query page with new DB selected so the dropdown refreshes
        NavigationManager.NavigateTo($"/sproutdb/admin?db={Uri.EscapeDataString(name)}", forceLoad: false);
    }

    private void RefreshDatabases()
    {
        databases.Clear();
        var dbs = Engine.GetDatabases();
        foreach (var db in dbs)
        {
            var node = new DbNode { Name = db.Name, Expanded = true };
            var describeResponse = Engine.Execute("describe", db.Name);
            if (describeResponse.Schema?.Tables is { } tables)
            {
                node.Tables = tables;
            }
            databases.Add(node);
        }
    }

    private void ToggleDb(DbNode db)
    {
        db.Expanded = !db.Expanded;
    }

    private void NavigateToTable(string dbName, string table)
    {
        NavigationManager.NavigateTo($"/sproutdb/admin?db={Uri.EscapeDataString(dbName)}&q={Uri.EscapeDataString($"get {table}")}");
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
        _activitySubscription?.Dispose();
    }

    private sealed class DbNode
    {
        public string Name { get; set; } = string.Empty;
        public List<string> Tables { get; set; } = new();
        public bool Expanded { get; set; }
    }

    private sealed class ActivityItem
    {
        public string Label { get; set; } = string.Empty;
        public string Target { get; set; } = string.Empty;
        public string DotClass { get; set; } = string.Empty;
        public DateTime Timestamp { get; set; }
    }
}
