<!DOCTYPE html>
<html lang="en">
<head>
    <base href="/" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SproutDB Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="/_content/SproutDB/css/sproutdb-admin.css" rel="stylesheet" />
    <script src="/_content/SproutDB/js/sproutdb-autocomplete.js"></script>
    <HeadOutlet />
</head>
<body>
    <Routes @rendermode="InteractiveServer" />

    <div id="components-reconnect-modal" class="sprout-reconnect">
        <div class="sprout-reconnect-card">
            <div class="sprout-reconnect-scene">
                <div class="sprout-reconnect-soil"></div>
                <div class="sprout-reconnect-plant">
                    <div class="sprout-reconnect-crown"></div>
                    <div class="sprout-reconnect-stem"></div>
                    <div class="sprout-reconnect-leaf sprout-reconnect-leaf-l"></div>
                    <div class="sprout-reconnect-leaf sprout-reconnect-leaf-r"></div>
                </div>
            </div>
            <div class="sprout-reconnect-text">Planting a tree &mdash; be right back</div>
            <div class="sprout-reconnect-dots"><span>.</span><span>.</span><span>.</span></div>
        </div>
    </div>

    <script>
        (function() {
            var t = localStorage.getItem('sproutdb-theme') || 'dark';
            document.documentElement.setAttribute('data-theme', t);
            window.sproutAdmin = {
                getTheme: function() { return document.documentElement.getAttribute('data-theme') || 'dark'; },
                setTheme: function(theme) {
                    document.documentElement.setAttribute('data-theme', theme);
                    localStorage.setItem('sproutdb-theme', theme);
                },
                initEditor: function(wrapEl) {
                    if (!wrapEl || wrapEl._editorInit) return;
                    wrapEl._editorInit = true;
                    var ta = wrapEl.querySelector('textarea');
                    var pre = wrapEl.querySelector('pre');
                    if (!ta || !pre) return;
                    ta.addEventListener('scroll', function() {
                        pre.scrollTop = ta.scrollTop;
                        pre.scrollLeft = ta.scrollLeft;
                    });
                },

                // ── File download ──
                downloadFile: function(filename, content, mimeType) {
                    var blob = new Blob([content], { type: mimeType + ';charset=utf-8' });
                    var url = URL.createObjectURL(blob);
                    var a = document.createElement('a');
                    a.href = url;
                    a.download = filename;
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                    URL.revokeObjectURL(url);
                },

                // ── Blob open in new tab ──
                openBlob: function(base64, mime) {
                    var bin = atob(base64);
                    var bytes = new Uint8Array(bin.length);
                    for (var i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
                    var blob = new Blob([bytes], { type: mime });
                    var url = URL.createObjectURL(blob);
                    window.open(url, '_blank');
                },

                // ── Insert text at textarea cursor ──
                insertAtCursor: function(wrapEl, text) {
                    var ta = wrapEl ? wrapEl.querySelector('textarea') : null;
                    if (!ta) return '';
                    var pos = ta.selectionStart;
                    var before = ta.value.substring(0, pos);
                    var after = ta.value.substring(ta.selectionEnd);
                    ta.value = before + text + after;
                    var newPos = pos + text.length;
                    ta.setSelectionRange(newPos, newPos);
                    ta.dispatchEvent(new Event('input', { bubbles: true }));
                    ta.focus();
                    return ta.value;
                },

                // ── Schema store ──
                _schema: { tables: [], columns: {} },
                updateSchema: function(schema) {
                    sproutAdmin._schema = schema || { tables: [], columns: {} };
                },

                // ── Autocomplete engine ──
                initAutocomplete: function(wrapEl, dotnetRef) {
                    if (!wrapEl || wrapEl._acInit) return;
                    wrapEl._acInit = true;

                    var ta = wrapEl.querySelector('textarea');
                    if (!ta) return;

                    // Create popup on body so it's not clipped by overflow:hidden
                    var popup = document.createElement('div');
                    popup.className = 'ac-popup';
                    document.body.appendChild(popup);

                    // Create mirror for caret positioning
                    var mirror = document.createElement('div');
                    mirror.className = 'ac-mirror';
                    wrapEl.appendChild(mirror);

                    var sel = 0;
                    var items = [];
                    var visible = false;

                    function getContext(text, pos) {
                        return SproutAutocomplete.getContext(text, pos);
                    }

                    function getSuggestions(ctx) {
                        return SproutAutocomplete.getSuggestions(ctx, sproutAdmin._schema);
                    }

                    function positionPopup() {
                        var cs = getComputedStyle(ta);
                        mirror.style.fontFamily = cs.fontFamily;
                        mirror.style.fontSize = cs.fontSize;
                        mirror.style.lineHeight = cs.lineHeight;
                        mirror.style.padding = cs.padding;
                        mirror.style.width = cs.width;
                        mirror.style.letterSpacing = cs.letterSpacing;
                        mirror.style.wordSpacing = cs.wordSpacing;
                        mirror.style.tabSize = cs.tabSize;

                        var textBefore = ta.value.substring(0, ta.selectionStart);
                        mirror.textContent = '';
                        var span = document.createElement('span');
                        span.textContent = textBefore;
                        mirror.appendChild(span);
                        var caret = document.createElement('span');
                        caret.textContent = '|';
                        mirror.appendChild(caret);

                        var caretRect = caret.getBoundingClientRect();
                        var lineH = parseInt(cs.lineHeight) || 22;

                        popup.style.left = caretRect.left + 'px';
                        popup.style.top = (caretRect.top + lineH) + 'px';
                    }

                    function show(sugg, cat) {
                        items = sugg;
                        sel = 0;
                        if (items.length === 0) { hide(); return; }
                        popup.innerHTML = '';
                        for (var i = 0; i < items.length; i++) {
                            var div = document.createElement('div');
                            div.className = 'ac-item' + (i === 0 ? ' active' : '');
                            div.innerHTML = '<span class="ac-cat">' + cat + '</span>' + escapeHtml(items[i]);
                            div.dataset.idx = i;
                            div.addEventListener('mousedown', function(e) {
                                e.preventDefault();
                                accept(parseInt(this.dataset.idx));
                            });
                            popup.appendChild(div);
                        }
                        positionPopup();
                        popup.classList.add('visible');
                        visible = true;
                    }

                    function hide() {
                        popup.classList.remove('visible');
                        visible = false;
                        items = [];
                    }

                    function highlight(idx) {
                        var children = popup.children;
                        for (var i = 0; i < children.length; i++) {
                            children[i].classList.toggle('active', i === idx);
                        }
                        sel = idx;
                        // Scroll into view
                        if (children[idx]) children[idx].scrollIntoView({ block: 'nearest' });
                    }

                    function accept(idx) {
                        if (idx < 0 || idx >= items.length) return;
                        var val = items[idx];
                        var pos = ta.selectionStart;
                        var text = ta.value;
                        var ctx = getContext(text, pos);
                        var prefixLen = (ctx.prefix || '').length;

                        // Handle table.col prefix pattern
                        if (ctx.type === 'column' && text.substring(0, pos).lastIndexOf('.') > text.substring(0, pos).lastIndexOf(' ')) {
                            var dotPos = text.substring(0, pos).lastIndexOf('.');
                            prefixLen = pos - dotPos - 1;
                        }

                        var before = text.substring(0, pos - prefixLen);
                        var after = text.substring(pos);
                        var newVal = before + val + (after.length === 0 || after[0] !== ' ' ? ' ' : '') + after;
                        ta.value = newVal;
                        var newPos = before.length + val.length + 1;
                        ta.setSelectionRange(newPos, newPos);

                        // Dispatch input event for Blazor binding
                        ta.dispatchEvent(new Event('input', { bubbles: true }));

                        // Sync to Blazor for highlight update
                        if (dotnetRef) {
                            dotnetRef.invokeMethodAsync('OnAutoCompleteInput', ta.value);
                        }

                        hide();
                    }

                    function escapeHtml(s) {
                        var d = document.createElement('span');
                        d.textContent = s;
                        return d.innerHTML;
                    }

                    function trigger() {
                        var ctx = getContext(ta.value, ta.selectionStart);
                        var result = getSuggestions(ctx);
                        if (result.items.length > 0) {
                            show(result.items, result.cat);
                        } else {
                            hide();
                        }
                    }

                    ta.addEventListener('input', function() { trigger(); });

                    ta.addEventListener('keydown', function(e) {
                        // Ctrl+Space force trigger
                        if (e.ctrlKey && e.key === ' ') {
                            e.preventDefault();
                            trigger();
                            return;
                        }

                        if (!visible) return;

                        if (e.key === 'ArrowDown') {
                            e.preventDefault();
                            highlight((sel + 1) % items.length);
                        } else if (e.key === 'ArrowUp') {
                            e.preventDefault();
                            highlight((sel - 1 + items.length) % items.length);
                        } else if (e.key === 'Tab' || e.key === 'Enter') {
                            // Only intercept if popup is visible
                            e.preventDefault();
                            e.stopPropagation();
                            accept(sel);
                        } else if (e.key === 'Escape') {
                            e.preventDefault();
                            hide();
                        }
                    });

                    ta.addEventListener('blur', function() {
                        // Small delay so mousedown on popup items fires first
                        setTimeout(hide, 150);
                    });
                }
            };
        })();
    </script>
    <script src="/_framework/blazor.web.js"></script>
</body>
</html>
