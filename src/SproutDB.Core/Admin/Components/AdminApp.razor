<!DOCTYPE html>
<html lang="en">
<head>
    <base href="/" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SproutDB Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="/_content/SproutDB.Core/css/sproutdb-admin.css" rel="stylesheet" />
    <HeadOutlet />
</head>
<body>
    <Routes @rendermode="InteractiveServer" />

    <div id="components-reconnect-modal" class="sprout-reconnect">
        <div class="sprout-reconnect-card">
            <div class="sprout-reconnect-scene">
                <div class="sprout-reconnect-soil"></div>
                <div class="sprout-reconnect-plant">
                    <div class="sprout-reconnect-crown"></div>
                    <div class="sprout-reconnect-stem"></div>
                    <div class="sprout-reconnect-leaf sprout-reconnect-leaf-l"></div>
                    <div class="sprout-reconnect-leaf sprout-reconnect-leaf-r"></div>
                </div>
            </div>
            <div class="sprout-reconnect-text">Planting a tree &mdash; be right back</div>
            <div class="sprout-reconnect-dots"><span>.</span><span>.</span><span>.</span></div>
        </div>
    </div>

    <script src="/_framework/blazor.web.js"></script>
</body>
</html>
