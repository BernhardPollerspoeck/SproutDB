    private void GoToPrevPage()
    {
        if (Tab.LastResponse?.Paging is not { } pg || pg.Page <= 1)
            return;

        var prevPage = pg.Page - 1;
        // Build prev query by replacing page number
        var prevQuery = System.Text.RegularExpressions.Regex.Replace(
            pg.Next ?? QueryText,
            @"page\s+\d+",
            $"page {prevPage}",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        RunNextPage(prevQuery);
    }

