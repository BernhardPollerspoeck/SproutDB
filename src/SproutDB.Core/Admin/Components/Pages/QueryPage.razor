@page "/sproutdb/admin"
@using SproutDB.Core.Admin
@using SproutDB.Core.Parsing
@implements IDisposable

<!-- Query Tabs -->
<div class="query-tabs">
    @for (var idx = 0; idx < Workspace.Tabs.Count; idx++)
    {
        var i = idx;
        var tab = Workspace.Tabs[i];
        var isActive = i == Workspace.ActiveTabIndex;
        <button class="query-tab @(isActive ? "active" : "")" @onclick="() => SwitchTab(i)">
            @if (tab.HasChanges)
            {
                <span class="query-tab-dot">●</span>
            }
            @tab.Title
            <span class="query-tab-close" @onclick="() => CloseTab(i)" @onclick:stopPropagation="true">×</span>
        </button>
    }
    <button class="query-tab-add" @onclick="AddTab" title="New tab">+</button>
</div>

<!-- Query Editor -->
<div class="query-section">
    <div class="query-toolbar">
        <select class="query-db-select" @bind="selectedDatabase" @bind:after="OnDatabaseChanged">
            <option value="">(select database)</option>
            @foreach (var db in databases)
            {
                <option value="@db.Name">@db.Name</option>
            }
        </select>
        <div class="query-toolbar-sep"></div>
        <div class="saved-queries-wrap">
            <button class="btn btn-ghost @(_showSaved ? "btn-ghost-active" : "")" style="font-size: 11px; padding: 3px 8px;" @onclick="ToggleSaved">Saved</button>
            @if (_showSaved)
            {
                <div class="saved-queries-dropdown">
                    @if (_savedQueries is { Count: > 0 })
                    {
                        var pinned = _savedQueries.Where(q => q.Pinned).ToList();
                        var unpinned = _savedQueries.Where(q => !q.Pinned).ToList();
                        @foreach (var sq in pinned)
                        {
                            var captured = sq;
                            <div class="saved-query-item" @onclick="() => LoadSavedQuery(captured)">
                                <span class="saved-query-pin pinned" @onclick="() => TogglePin(captured)" @onclick:stopPropagation="true">📌</span>
                                <span class="saved-query-name">@sq.Name</span>
                                <button class="saved-query-delete" @onclick="() => DeleteSavedQuery(captured)" @onclick:stopPropagation="true">×</button>
                            </div>
                        }
                        @if (pinned.Count > 0 && unpinned.Count > 0)
                        {
                            <div class="saved-query-sep"></div>
                        }
                        @foreach (var sq in unpinned)
                        {
                            var captured = sq;
                            <div class="saved-query-item" @onclick="() => LoadSavedQuery(captured)">
                                <span class="saved-query-pin" @onclick="() => TogglePin(captured)" @onclick:stopPropagation="true">📌</span>
                                <span class="saved-query-name">@sq.Name</span>
                                <button class="saved-query-delete" @onclick="() => DeleteSavedQuery(captured)" @onclick:stopPropagation="true">×</button>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="saved-query-empty">No saved queries</div>
                    }
                </div>
            }
        </div>
        <button class="btn btn-ghost @(_showHistory ? "btn-ghost-active" : "")" style="font-size: 11px; padding: 3px 8px;" @onclick="ToggleHistory">History</button>
        @if (Tab.LastResponse?.Paging is { } paging)
        {
            <span class="auto-paged-badge">&#9889; Page @paging.Page · @paging.PageSize rows of @paging.Total.ToString("N0")</span>
        }
        <span class="query-hint"><kbd>Ctrl</kbd> + <kbd>Enter</kbd></span>
    </div>
    @if (_showHistory)
    {
        <div class="query-history-panel">
            <div class="history-filter-row">
                <input type="text" class="history-filter-input" placeholder="Filter history..." @bind="_historyFilter" @bind:event="oninput" />
            </div>
            @if (_filteredHistory is { Count: > 0 })
            {
                @foreach (var item in _filteredHistory)
                {
                    <div class="history-item" @onclick="() => ApplyHistoryItem(item)">
                        <span class="history-op @GetHistoryOpClass(item.Operation)">@item.Operation</span>
                        <span class="history-query">@item.Query</span>
                        <span class="history-db">@item.Database</span>
                        <span class="history-time">@FormatRelativeTime(item.Timestamp)</span>
                    </div>
                }
            }
            else
            {
                <div style="padding: 12px; font-size: 11.5px; color: var(--text-3); font-style: italic;">No history</div>
            }
        </div>
    }
    <div class="query-editor-wrap" @ref="_editorWrapRef">
        <pre class="query-editor-highlight" aria-hidden="true">@_highlightedQuery </pre>
        <textarea class="query-editor"
                  spellcheck="false"
                  placeholder="Enter SproutDB query..."
                  @bind="QueryText"
                  @bind:event="oninput"
                  @onkeydown="HandleKeyDown"></textarea>
    </div>
    <div class="query-actions">
        <button class="btn btn-primary" @onclick="RunQuery">&#9654; Run</button>
        <button class="btn btn-ghost" @onclick="FormatQuery">Format</button>
        <button class="btn btn-ghost" @onclick="TriggerBlobPicker" title="Attach file as base64">&#128206; Blob</button>
        <InputFile @ref="_blobFileInput" OnChange="OnBlobFileSelected" style="display: none;" />
        @if (_showSaveDialog)
        {
            <div class="save-dialog">
                <input type="text" placeholder="Query name..." @bind="_saveName" @bind:event="oninput"
                       @onkeyup="HandleSaveKeyUp" />
                <button class="btn btn-primary" style="font-size: 11px; padding: 3px 10px;" @onclick="SaveQuery" disabled="@(string.IsNullOrWhiteSpace(_saveName))">Save</button>
                <button class="btn btn-ghost" style="font-size: 11px; padding: 3px 8px;" @onclick="() => _showSaveDialog = false">Cancel</button>
            </div>
        }
        else
        {
            <button class="btn btn-ghost" @onclick="ShowSaveDialog">💾 Save</button>
        }
        @if (_runError is not null)
        {
            <span style="color: var(--red); font-size: 12px; font-weight: 500;">@_runError</span>
        }
        else if (Tab.LastResponse is not null)
        {
            <div class="query-stats @(_statsFlash ? "stats-flash" : "")">
                <span class="stat-ok">&#10003;</span>
                <span><span class="stat-value">@FormatElapsed(Tab.ElapsedMs)</span> <span class="stat-label">time</span></span>
                <span><span class="stat-value">@Tab.RowCount</span> <span class="stat-label">rows</span></span>
                <span><span class="stat-value">@FormatBytes(Tab.PayloadBytes)</span> <span class="stat-label">size</span></span>
            </div>
        }
    </div>
</div>

<!-- Results / Error -->
<div class="results-section">
    @if (Tab.LastResponse is not null && Tab.LastResponse.Operation == SproutOperation.Error)
    {
        <!-- Error display -->
        <div class="error-panel">
            <div class="error-panel-header">Query Error</div>
            @if (Tab.LastResponse.Errors is { Count: > 0 } errors)
            {
                @foreach (var err in errors)
                {
                    <div class="error-item">
                        <span class="error-code">@err.Code</span>
                        <span class="error-message">@err.Message</span>
                    </div>
                    @if (err.Code == "UNKNOWN_COLUMN" && err.Position >= 0 && err.Length > 0)
                    {
                        var availableCols = GetAvailableColumnsForError();
                        if (availableCols.Count > 0)
                        {
                            var capturedErr = err;
                            <div class="error-fix-row">
                                <span class="error-fix-label">Available:</span>
                                @foreach (var col in availableCols)
                                {
                                    var capturedCol = col;
                                    <button class="error-fix-badge" @onclick="() => FixColumnInQuery(capturedErr, capturedCol)">@col</button>
                                }
                            </div>
                        }
                    }
                }
            }
            @if (!string.IsNullOrEmpty(Tab.LastResponse.AnnotatedQuery))
            {
                <pre class="error-annotated">@Tab.LastResponse.AnnotatedQuery</pre>
            }
        </div>
    }
    else if (Tab.DisplayData is { Count: > 0 } data)
    {
        <!-- Results table -->
        <div class="results-tabs">
            <button class="results-tab @(Tab.ActiveResultTab == "results" ? "active" : "")" @onclick='() => Tab.ActiveResultTab = "results"'>Results <span class="tab-count">@data.Count</span></button>
            <button class="results-tab @(Tab.ActiveResultTab == "json" ? "active" : "")" @onclick="SwitchToJson">JSON</button>
            <div style="flex:1"></div>
            <button class="btn btn-ghost" style="font-size: 11px; padding: 3px 10px;" @onclick="ExportCsv">CSV</button>
            <button class="btn btn-ghost" style="font-size: 11px; padding: 3px 10px;" @onclick="ExportJson">JSON</button>
        </div>
        @if (Tab.ActiveResultTab == "json")
        {
            <div class="json-panel">
                <div class="json-toolbar">
                    @if (_jsonCopied)
                    {
                        <span class="json-copied">Copied</span>
                    }
                    <button class="btn btn-ghost" style="font-size: 11px; padding: 3px 10px;" @onclick="CopyJson">Copy</button>
                </div>
                <pre class="json-content">@_jsonDisplay</pre>
            </div>
        }
        else
        {
        <div class="results-table-wrap">
            <table class="results-table">
                <thead>
                    <tr>
                        <th class="row-number-header">#</th>
                        @foreach (var col in Tab.Columns)
                        {
                            var isSorted = Tab.SortColumn is not null
                                && string.Equals(col.Name, Tab.SortColumn, StringComparison.OrdinalIgnoreCase);
                            <th>
                                <div class="th-content">
                                    @col.Name
                                    @if (isSorted)
                                    {
                                        <span class="th-sort">@(Tab.SortDesc ? "\u25BC" : "\u25B2")</span>
                                    }
                                    <span class="th-type">@col.Type</span>
                                </div>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @{ var rowIndex = 0; }
                    @foreach (var row in data)
                    {
                        var rowId = GetRowId(row);
                        var rowKey = rowIndex++;
                        <tr @key="rowKey" class="@GetRowFlashClass(rowId)">
                            <td class="row-number">@(rowKey + 1)</td>
                            @foreach (var col in Tab.Columns)
                            {
                                row.TryGetValue(col.Name, out var cellValue);
                                @if (_editingRowId is not null && _editingRowId == rowId && _editingColumn == col.Name && _editingBlob)
                                {
                                    <td class="cell-blob cell-editing">
                                        <button class="btn btn-primary" style="font-size: 11px; padding: 3px 10px;" @onclick="TriggerInlineBlobPicker">&#128206; Choose file</button>
                                        <InputFile @ref="_inlineBlobInput" OnChange="OnInlineBlobSelected" style="display: none;" />
                                        <button class="blob-btn" @onclick="CancelEdit" title="Cancel">&#10005;</button>
                                        @if (_editError is not null)
                                        {
                                            <div class="cell-edit-error">@_editError</div>
                                        }
                                    </td>
                                }
                                else if (_editingRowId is not null && _editingRowId == rowId && _editingColumn == col.Name)
                                {
                                    <td class="@GetCellClass(col, cellValue) cell-editing">
                                        <input @ref="_editInputRef"
                                               class="cell-edit-input"
                                               type="text"
                                               @bind="_editValue"
                                               @bind:event="oninput"
                                               @onkeyup="HandleEditKeyUp"
                                               @onblur="CommitEdit" />
                                        @if (_editError is not null)
                                        {
                                            <div class="cell-edit-error">@_editError</div>
                                        }
                                    </td>
                                }
                                else if (col.Type == "blob" && cellValue is string blobBase64 && blobBase64.Length > 0)
                                {
                                    <td>
                                        <div class="cell-blob">
                                            <span class="blob-badge">BLOB @FormatBlobSize(blobBase64)</span>
                                            <button class="blob-btn" title="Open in new tab" @onclick="() => OpenBlobInTab(blobBase64)" @onclick:stopPropagation="true">Open</button>
                                            <button class="blob-btn" title="Download" @onclick="() => DownloadBlob(blobBase64, col.Name, rowId)" @onclick:stopPropagation="true">Save</button>
                                            @if (Tab.CanEdit && Tab.HasIdColumn)
                                            {
                                                <button class="blob-btn" title="Replace" @onclick="() => StartEdit(rowId, col.Name, cellValue)" @onclick:stopPropagation="true">&#128206;</button>
                                            }
                                        </div>
                                    </td>
                                }
                                else if (col.Type == "blob" && Tab.CanEdit && Tab.HasIdColumn)
                                {
                                    <td class="cell-editable" @ondblclick="() => StartEdit(rowId, col.Name, cellValue)">
                                        <div class="cell-blob">
                                            <span class="cell-null">null</span>
                                            <button class="blob-btn" title="Upload" @onclick="() => StartEdit(rowId, col.Name, cellValue)" @onclick:stopPropagation="true">&#128206;</button>
                                        </div>
                                    </td>
                                }
                                else if (col.Type == "blob")
                                {
                                    <td class="cell-null">null</td>
                                }
                                else if (col.Type == "array" && cellValue is List<object?> arr)
                                {
                                    <td>
                                        <div class="cell-array">
                                            <span class="array-badge">[@arr.Count]</span>
                                            @foreach (var elem in arr)
                                            {
                                                <span class="array-elem">@(elem?.ToString() ?? "null")</span>
                                            }
                                        </div>
                                    </td>
                                }
                                else if (col.Type == "array")
                                {
                                    <td class="cell-null">null</td>
                                }
                                else
                                {
                                    @if (Tab.CanEdit && col.Name != "_id" && Tab.HasIdColumn)
                                    {
                                        <td class="@GetCellClass(col, cellValue) cell-editable"
                                            @ondblclick="() => StartEdit(rowId, col.Name, cellValue)">
                                            @FormatCell(cellValue)
                                            <span class="cell-edit-icon" @onclick="() => StartEdit(rowId, col.Name, cellValue)" @onclick:stopPropagation="true">&#9998;</span>
                                        </td>
                                    }
                                    else
                                    {
                                        <td class="@GetCellClass(col, cellValue)">
                                            @FormatCell(cellValue)
                                        </td>
                                    }
                                }
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        }
        @if (Tab.LastResponse?.Paging is { } pg)
        {
            var start = (pg.Page - 1) * pg.PageSize + 1;
            var end = Math.Min(pg.Page * pg.PageSize, pg.Total);
            var totalPages = (pg.Total + pg.PageSize - 1) / pg.PageSize;
            <div class="paging-bar">
                <span class="paging-info">Showing @start–@end of @pg.Total.ToString("N0") rows · Page @pg.Page of @totalPages</span>
                <div class="paging-buttons">
                    <button class="btn btn-ghost paging-btn" disabled="@(pg.Page <= 1)" @onclick="GoToPrevPage">Prev</button>
                    <button class="btn btn-ghost paging-btn" disabled="@(pg.Next is null)" @onclick="GoToNextPage">Next</button>
                </div>
            </div>
            @if (pg.Next is not null)
            {
                <div class="paging-next-row">
                    <input type="text" class="paging-next-query" readonly value="@pg.Next" />
                    <button class="btn btn-ghost" style="font-size: 11px; padding: 3px 10px; flex-shrink:0;" @onclick="() => CopyToClipboard(pg.Next)">Copy</button>
                    <button class="btn btn-primary" style="font-size: 11px; padding: 3px 10px; flex-shrink:0;" @onclick="() => RunNextPage(pg.Next)">Run</button>
                </div>
            }
        }
    }
    else if (Tab.LastResponse is not null)
    {
        <!-- Non-data response (e.g. upsert, delete, describe) -->
        <div class="results-tabs">
            <button class="results-tab active">Result</button>
        </div>
        <div class="results-table-wrap">
            <div style="padding: 16px;">
                <div class="admin-status success" style="font-size: 14px; padding: 12px 16px;">
                    <span style="font-weight: 600;">@Tab.LastResponse.Operation</span> completed — @Tab.LastResponse.Affected row(s) affected
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- No query run yet -->
        <div class="results-tabs">
            <button class="results-tab active">Results</button>
        </div>
        <div class="results-table-wrap">
            <div class="placeholder-page">
                <div class="placeholder-title" style="font-size: 14px;">Run a query to see results</div>
                <div class="placeholder-subtitle">Use the editor above or click a table in the sidebar</div>
            </div>
        </div>
    }
</div>

@code {
    [Inject]
    private SproutEngine Engine { get; set; } = default!;

    [Inject]
    private IJSRuntime JS { get; set; } = default!;

    [Inject]
    private QueryWorkspaceState Workspace { get; set; } = default!;

    [SupplyParameterFromQuery(Name = "db")]
    private string? DbParam { get; set; }

    [SupplyParameterFromQuery(Name = "q")]
    private string? QParam { get; set; }

    private IReadOnlyList<ISproutDatabase> databases => Engine.GetDatabases();
    private QueryTab Tab => Workspace.ActiveTab;

    // Convenience accessors that bridge Tab state to local binding
    private string selectedDatabase
    {
        get => Tab.Database;
        set => Tab.Database = value;
    }

    private MarkupString _highlightedQuery;

    private string QueryText
    {
        get => Tab.QueryText;
        set
        {
            Tab.QueryText = value;
            _highlightedQuery = SyntaxHighlighter.Highlight(value);
        }
    }

    private bool autoExecuted;
    private bool _statsFlash;
    private System.Threading.Timer? _statsFlashTimer;

    // Live-update state
    private IDisposable? _tableSubscription;
    private string? _subscribedDb;
    private string? _subscribedTable;
    private readonly HashSet<ulong> _flashGreenIds = new();
    private readonly HashSet<ulong> _flashRedIds = new();
    private System.Threading.Timer? _flashTimer;
    private List<Dictionary<string, object?>>? _pendingData;

    // Editor overlay
    private ElementReference _editorWrapRef;
    private bool _editorInitialized;

    // Autocomplete
    private DotNetObjectReference<QueryPage>? _dotnetRef;
    private string _lastSchemaDb = string.Empty;

    // History panel
    private bool _showHistory;
    private static readonly List<HistoryItem> _historyItems = new();
    private const int MaxHistoryItems = 50;
    private string _historyFilter = string.Empty;

    private List<HistoryItem> _filteredHistory =>
        string.IsNullOrEmpty(_historyFilter)
            ? _historyItems
            : _historyItems.Where(h =>
                h.Query.Contains(_historyFilter, StringComparison.OrdinalIgnoreCase) ||
                h.Operation.Contains(_historyFilter, StringComparison.OrdinalIgnoreCase) ||
                h.Database.Contains(_historyFilter, StringComparison.OrdinalIgnoreCase))
                .ToList();

    // Inline editing state
    private ElementReference _editInputRef;
    private bool _shouldFocusEdit;
    private ulong? _editingRowId;
    private string? _editingColumn;
    private string _editValue = string.Empty;
    private string? _editError;

    // Saved queries
    private bool _showSaved;
    private bool _showSaveDialog;
    private string _saveName = string.Empty;
    private List<SavedQueryEntry>? _savedQueries;

    // Blob file picker
    private InputFile? _blobFileInput;
    private InputFile? _inlineBlobInput;
    private bool _editingBlob;

    // JSON display
    private MarkupString _jsonDisplay;
    private bool _jsonCopied;

    protected override void OnInitialized()
    {
        // If first tab has no database set and there's only one, auto-select
        if (string.IsNullOrEmpty(Tab.Database) && databases.Count == 1)
        {
            Tab.Database = databases[0].Name;
        }

        // Sync highlight with current tab text
        _highlightedQuery = SyntaxHighlighter.Highlight(Tab.QueryText);

        // Load saved queries for initial database
        LoadSavedQueries();
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(DbParam))
        {
            selectedDatabase = DbParam;
        }

        if (!string.IsNullOrEmpty(QParam) && !autoExecuted)
        {
            QueryText = QParam;
            autoExecuted = true;
            RunQuery();
        }

        if (_editorInitialized && selectedDatabase != _lastSchemaDb)
        {
            _ = PushSchemaAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_editorInitialized)
        {
            _editorInitialized = true;
            await JS.InvokeVoidAsync("sproutAdmin.initEditor", _editorWrapRef);
            _dotnetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("sproutAdmin.initAutocomplete", _editorWrapRef, _dotnetRef);
            await JS.InvokeVoidAsync("eval",
                "document.addEventListener('keydown',function(e){if(e.altKey&&e.key==='l'){e.preventDefault();document.querySelector('.query-editor')?.focus();}})");
            await PushSchemaAsync();
        }

        if (_shouldFocusEdit)
        {
            _shouldFocusEdit = false;
            try { await _editInputRef.FocusAsync(); } catch { }
        }
    }

    // --- Tabs ---

    private void SwitchTab(int index)
    {
        if (index == Workspace.ActiveTabIndex) return;

        // Clean up live subscription for current tab
        _tableSubscription?.Dispose();
        _tableSubscription = null;
        _subscribedDb = null;
        _subscribedTable = null;
        CancelEdit();

        Workspace.ActiveTabIndex = index;

        // Sync local state with new tab
        _highlightedQuery = SyntaxHighlighter.Highlight(Tab.QueryText);
        _ = PushSchemaAsync();

        // Re-establish live subscription if the tab had results
        SetupLiveSubscription();
    }

    private void AddTab()
    {
        Workspace.AddTab(title: Workspace.NextTitle());
        _highlightedQuery = SyntaxHighlighter.Highlight(Tab.QueryText);

        // Auto-select database if only one
        if (string.IsNullOrEmpty(Tab.Database) && databases.Count == 1)
            Tab.Database = databases[0].Name;

        _ = PushSchemaAsync();
    }

    private void CloseTab(int index)
    {
        if (index == Workspace.ActiveTabIndex)
        {
            _tableSubscription?.Dispose();
            _tableSubscription = null;
            _subscribedDb = null;
            _subscribedTable = null;
        }

        Workspace.CloseTab(index);
        _highlightedQuery = SyntaxHighlighter.Highlight(Tab.QueryText);
        _ = PushSchemaAsync();
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e is { CtrlKey: true, Key: "Enter" })
        {
            RunQuery();
        }
    }

    private string? _runError;

    private void FormatQuery()
    {
        if (!string.IsNullOrWhiteSpace(QueryText))
            QueryText = SproutQueryFormatter.Format(QueryText);
    }

    private void RunQuery()
    {
        _runError = null;
        _appliedFixes.Clear();

        if (string.IsNullOrWhiteSpace(selectedDatabase))
        {
            _runError = "Select a database first";
            return;
        }

        if (string.IsNullOrWhiteSpace(QueryText))
            return;

        // Clear editing state
        CancelEdit();

        // Normalize: collapse formatted line breaks into a single query line
        var query = CollapseQuery(QueryText);
        if (query.Length == 0)
            return;

        var sw = System.Diagnostics.Stopwatch.StartNew();
        var response = Engine.Execute(query, selectedDatabase);
        sw.Stop();

        if (response.Operation != SproutOperation.Error)
        {
            RecordHistory(query, selectedDatabase, response.Operation.ToString().ToUpperInvariant());
        }

        Tab.LastResponse = response;
        Tab.ElapsedMs = sw.Elapsed.TotalMilliseconds;
        Tab.RowCount = response.Data?.Count ?? response.Affected;
        Tab.PayloadBytes = EstimatePayload(response);

        RebuildColumns(response, query);
        Tab.DisplayData = response.Data;

        ExtractSort(query);

        if (Tab.ActiveResultTab == "json" && Tab.DisplayData is { Count: > 0 })
            _jsonDisplay = HighlightJson(BuildJsonString());

        // Flash the stats bar to signal execution
        _statsFlash = true;
        _statsFlashTimer?.Dispose();
        _statsFlashTimer = new System.Threading.Timer(_ =>
        {
            _statsFlash = false;
            InvokeAsync(StateHasChanged);
        }, null, 1200, Timeout.Infinite);

        // Set up live subscription for Get queries
        SetupLiveSubscription();
    }

    private void RebuildColumns(SproutResponse response, string query)
    {
        Tab.Columns.Clear();
        Tab.HasIdColumn = false;

        if (response.Data is not { Count: > 0 } data)
            return;

        var firstRow = data[0];
        var tableName = ExtractTableName(query);
        Dictionary<string, ColumnInfo>? schemaMap = null;

        if (tableName is not null)
        {
            var describeResponse = Engine.Execute($"describe {tableName}", selectedDatabase);
            if (describeResponse.Schema?.Columns is { } cols)
            {
                schemaMap = new Dictionary<string, ColumnInfo>(StringComparer.OrdinalIgnoreCase);
                foreach (var c in cols)
                {
                    schemaMap[c.Name] = c;
                }
            }
        }

        foreach (var key in firstRow.Keys)
        {
            if (key == "_id") Tab.HasIdColumn = true;

            var type = "unknown";
            if (schemaMap is not null && schemaMap.TryGetValue(key, out var colInfo))
            {
                type = colInfo.Type;
            }
            else
            {
                var val = firstRow[key];
                type = val switch
                {
                    null => "null",
                    string => "string",
                    bool => "bool",
                    DateTime => "datetime",
                    int or long or ulong or uint => "long",
                    float or double or decimal => "double",
                    _ => val.GetType().Name.ToLowerInvariant()
                };
            }
            Tab.Columns.Add(new ColumnMeta { Name = key, Type = type });
        }
    }

    private void SetupLiveSubscription()
    {
        // Dispose previous subscription
        _tableSubscription?.Dispose();
        _tableSubscription = null;
        _subscribedDb = null;
        _subscribedTable = null;
        Tab.CanEdit = false;
        _flashGreenIds.Clear();
        _flashRedIds.Clear();

        if (Tab.LastResponse?.Operation != SproutOperation.Get || Tab.DisplayData is not { Count: > 0 })
            return;

        var tableName = ExtractTableName(QueryText);
        if (tableName is null)
            return;

        _subscribedDb = selectedDatabase;
        _subscribedTable = tableName;
        Tab.CanEdit = Tab.HasIdColumn;

        _tableSubscription = Engine.ChangeNotifier.Subscribe(selectedDatabase, tableName, OnTableChanged);
    }

    private void OnTableChanged(SproutResponse _)
    {
        if (Tab.LastResponse is null)
            return;

        if (_subscribedDb is null || _subscribedTable is null)
            return;

        // Re-run the query to get fresh data
        var query = CollapseQuery(QueryText);
        var freshResponse = Engine.Execute(query, _subscribedDb);
        if (freshResponse.Operation == SproutOperation.Error || freshResponse.Data is null)
            return;

        var oldIds = CollectIds(Tab.DisplayData);
        var newIds = CollectIds(freshResponse.Data);

        // New rows: in new but not in old
        foreach (var id in newIds)
        {
            if (!oldIds.Contains(id))
                _flashGreenIds.Add(id);
        }

        // Deleted rows: in old but not in new
        var deletedIds = new HashSet<ulong>();
        foreach (var id in oldIds)
        {
            if (!newIds.Contains(id))
                deletedIds.Add(id);
        }

        if (deletedIds.Count > 0)
        {
            // Keep old data visible during flash, mark deleted rows red
            foreach (var id in deletedIds)
                _flashRedIds.Add(id);

            // Store new data for later swap
            _pendingData = freshResponse.Data;
        }
        else
        {
            Tab.DisplayData = freshResponse.Data;
            Tab.RowCount = freshResponse.Data.Count;
        }

        // Clear flash after 1.5 seconds
        _flashTimer?.Dispose();
        _flashTimer = new System.Threading.Timer(ClearFlash, null, 1500, Timeout.Infinite);

        InvokeAsync(StateHasChanged);
    }

    private void ClearFlash(object? state)
    {
        _flashGreenIds.Clear();
        _flashRedIds.Clear();

        // Swap to pending data if we were showing deleted rows
        if (_pendingData is not null)
        {
            Tab.DisplayData = _pendingData;
            Tab.RowCount = _pendingData.Count;
            _pendingData = null;
        }

        InvokeAsync(StateHasChanged);
    }

    private static HashSet<ulong> CollectIds(List<Dictionary<string, object?>>? data)
    {
        var ids = new HashSet<ulong>();
        if (data is null) return ids;

        foreach (var row in data)
        {
            if (row.TryGetValue("_id", out var idVal) && idVal is ulong id)
                ids.Add(id);
        }
        return ids;
    }

    private static ulong? GetRowId(Dictionary<string, object?> row)
    {
        if (row.TryGetValue("_id", out var idVal) && idVal is ulong id)
            return id;
        return null;
    }

    private string GetRowFlashClass(ulong? rowId)
    {
        if (rowId is null) return "";
        if (_flashGreenIds.Contains(rowId.Value)) return "row-flash-green";
        if (_flashRedIds.Contains(rowId.Value)) return "row-flash-red";
        return "";
    }

