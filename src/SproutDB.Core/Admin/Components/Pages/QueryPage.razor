@page "/sproutdb/admin"
@implements IDisposable

<!-- Query Editor -->
<div class="query-section">
    <div class="query-toolbar">
        <select class="query-db-select" @bind="selectedDatabase">
            <option value="">(select database)</option>
            @foreach (var db in databases)
            {
                <option value="@db.Name">@db.Name</option>
            }
        </select>
        <div class="query-toolbar-sep"></div>
        <button class="btn btn-ghost" style="font-size: 11px; padding: 3px 8px;">History</button>
        <span class="auto-paged-badge">&#9889; auto-paged</span>
        <span class="query-hint"><kbd>Ctrl</kbd> + <kbd>Enter</kbd></span>
    </div>
    <textarea class="query-editor"
              spellcheck="false"
              placeholder="Enter SproutDB query..."
              @bind="queryText"
              @onkeydown="HandleKeyDown"></textarea>
    <div class="query-actions">
        <button class="btn btn-primary" @onclick="RunQuery">&#9654; Run</button>
        <button class="btn btn-ghost">Format</button>
        @if (lastResponse is not null)
        {
            <div class="query-stats">
                <span><span class="stat-value">@FormatElapsed(elapsedMs)</span> <span class="stat-label">time</span></span>
                <span><span class="stat-value">@rowCount</span> <span class="stat-label">rows</span></span>
                <span><span class="stat-value">@FormatBytes(payloadBytes)</span> <span class="stat-label">size</span></span>
            </div>
        }
    </div>
</div>

<!-- Results / Error -->
<div class="results-section">
    @if (lastResponse is not null && lastResponse.Operation == SproutOperation.Error)
    {
        <!-- Error display -->
        <div class="error-panel">
            <div class="error-panel-header">Query Error</div>
            @if (lastResponse.Errors is { Count: > 0 } errors)
            {
                @foreach (var err in errors)
                {
                    <div class="error-item">
                        <span class="error-code">@err.Code</span>
                        <span class="error-message">@err.Message</span>
                    </div>
                }
            }
            @if (!string.IsNullOrEmpty(lastResponse.AnnotatedQuery))
            {
                <pre class="error-annotated">@lastResponse.AnnotatedQuery</pre>
            }
        </div>
    }
    else if (_displayData is { Count: > 0 } data)
    {
        <!-- Results table -->
        <div class="results-tabs">
            <button class="results-tab active">Results <span class="tab-count">@data.Count</span></button>
        </div>
        <div class="results-table-wrap">
            <table class="results-table">
                <thead>
                    <tr>
                        @foreach (var col in columns)
                        {
                            <th>
                                <div class="th-content">
                                    @col.Name
                                    <span class="th-type">@col.Type</span>
                                </div>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in data)
                    {
                        var rowId = GetRowId(row);
                        <tr @key="rowId" class="@GetRowFlashClass(rowId)">
                            @foreach (var col in columns)
                            {
                                row.TryGetValue(col.Name, out var cellValue);
                                @if (_editingRowId is not null && _editingRowId == rowId && _editingColumn == col.Name)
                                {
                                    <td class="@GetCellClass(col, cellValue)">
                                        <input @ref="_editInputRef"
                                               class="cell-edit-input"
                                               type="text"
                                               value="@_editValue"
                                               @oninput="OnEditInput"
                                               @onkeyup="HandleEditKeyUp" />
                                        @if (_editError is not null)
                                        {
                                            <div class="cell-edit-error">@_editError</div>
                                        }
                                    </td>
                                }
                                else
                                {
                                    <td class="@GetCellClass(col, cellValue)">
                                        @FormatCell(cellValue)
                                        @if (_canEdit && col.Name != "_id" && _hasIdColumn)
                                        {
                                            <span class="cell-edit-icon" @onclick="() => StartEdit(rowId, col.Name, cellValue)" @onclick:stopPropagation="true">&#9998;</span>
                                        }
                                    </td>
                                }
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (lastResponse is not null)
    {
        <!-- Non-data response (e.g. upsert, delete, describe) -->
        <div class="results-tabs">
            <button class="results-tab active">Result</button>
        </div>
        <div class="results-table-wrap">
            <div class="placeholder-page">
                <div class="placeholder-title" style="font-size: 14px;">@lastResponse.Operation completed</div>
                <div class="placeholder-subtitle">@lastResponse.Affected row(s) affected</div>
            </div>
        </div>
    }
    else
    {
        <!-- No query run yet -->
        <div class="results-tabs">
            <button class="results-tab active">Results</button>
        </div>
        <div class="results-table-wrap">
            <div class="placeholder-page">
                <div class="placeholder-title" style="font-size: 14px;">Run a query to see results</div>
                <div class="placeholder-subtitle">Use the editor above or click a table in the sidebar</div>
            </div>
        </div>
    }
</div>

@code {
    [Inject]
    private SproutEngine Engine { get; set; } = default!;

    [SupplyParameterFromQuery(Name = "db")]
    private string? DbParam { get; set; }

    [SupplyParameterFromQuery(Name = "q")]
    private string? QParam { get; set; }

    private IReadOnlyList<ISproutDatabase> databases = [];
    private string selectedDatabase = string.Empty;
    private string queryText = string.Empty;

    private SproutResponse? lastResponse;
    private double elapsedMs;
    private int rowCount;
    private int payloadBytes;
    private List<ColumnMeta> columns = new();

    private bool autoExecuted;

    // Live-update state
    private IDisposable? _tableSubscription;
    private string? _subscribedDb;
    private string? _subscribedTable;
    private List<Dictionary<string, object?>>? _displayData;
    private readonly HashSet<ulong> _flashGreenIds = new();
    private readonly HashSet<ulong> _flashRedIds = new();
    private System.Threading.Timer? _flashTimer;
    private List<Dictionary<string, object?>>? _pendingData;
    private bool _canEdit;
    private bool _hasIdColumn;

    // Inline editing state
    private ElementReference _editInputRef;
    private bool _shouldFocusEdit;
    private ulong? _editingRowId;
    private string? _editingColumn;
    private string _editValue = string.Empty;
    private string? _editError;

    protected override void OnInitialized()
    {
        databases = Engine.GetDatabases();
        if (databases.Count == 1)
        {
            selectedDatabase = databases[0].Name;
        }
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(DbParam))
        {
            selectedDatabase = DbParam;
        }

        if (!string.IsNullOrEmpty(QParam) && !autoExecuted)
        {
            queryText = QParam;
            autoExecuted = true;
            RunQuery();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldFocusEdit)
        {
            _shouldFocusEdit = false;
            try { await _editInputRef.FocusAsync(); } catch { }
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e is { CtrlKey: true, Key: "Enter" })
        {
            RunQuery();
        }
    }

    private void RunQuery()
    {
        if (string.IsNullOrWhiteSpace(selectedDatabase) || string.IsNullOrWhiteSpace(queryText))
            return;

        // Clear editing state
        CancelEdit();

        var sw = System.Diagnostics.Stopwatch.StartNew();
        lastResponse = Engine.Execute(queryText.Trim(), selectedDatabase);
        sw.Stop();

        elapsedMs = sw.Elapsed.TotalMilliseconds;
        rowCount = lastResponse.Data?.Count ?? lastResponse.Affected;
        payloadBytes = EstimatePayload(lastResponse);

        RebuildColumns(lastResponse, queryText);
        _displayData = lastResponse.Data;

        // Set up live subscription for Get queries
        SetupLiveSubscription();
    }

    private void RebuildColumns(SproutResponse response, string query)
    {
        columns.Clear();
        _hasIdColumn = false;

        if (response.Data is not { Count: > 0 } data)
            return;

        var firstRow = data[0];
        var tableName = ExtractTableName(query);
        Dictionary<string, ColumnInfo>? schemaMap = null;

        if (tableName is not null)
        {
            var describeResponse = Engine.Execute($"describe {tableName}", selectedDatabase);
            if (describeResponse.Schema?.Columns is { } cols)
            {
                schemaMap = new Dictionary<string, ColumnInfo>(StringComparer.OrdinalIgnoreCase);
                foreach (var c in cols)
                {
                    schemaMap[c.Name] = c;
                }
            }
        }

        foreach (var key in firstRow.Keys)
        {
            if (key == "_id") _hasIdColumn = true;

            var type = "unknown";
            if (schemaMap is not null && schemaMap.TryGetValue(key, out var colInfo))
            {
                type = colInfo.Type;
            }
            else
            {
                var val = firstRow[key];
                type = val switch
                {
                    null => "null",
                    string => "string",
                    bool => "bool",
                    DateTime => "datetime",
                    int or long or ulong or uint => "long",
                    float or double or decimal => "double",
                    _ => val.GetType().Name.ToLowerInvariant()
                };
            }
            columns.Add(new ColumnMeta { Name = key, Type = type });
        }
    }

    private void SetupLiveSubscription()
    {
        // Dispose previous subscription
        _tableSubscription?.Dispose();
        _tableSubscription = null;
        _subscribedDb = null;
        _subscribedTable = null;
        _canEdit = false;
        _flashGreenIds.Clear();
        _flashRedIds.Clear();

        if (lastResponse?.Operation != SproutOperation.Get || lastResponse.Data is not { Count: > 0 })
            return;

        var tableName = ExtractTableName(queryText);
        if (tableName is null)
            return;

        _subscribedDb = selectedDatabase;
        _subscribedTable = tableName;
        _canEdit = _hasIdColumn;

        _tableSubscription = Engine.ChangeNotifier.Subscribe(selectedDatabase, tableName, OnTableChanged);
    }

    private void OnTableChanged(SproutResponse _)
    {
        // Skip live updates while inline editing is active
        if (_editingRowId is not null)
            return;

        if (_subscribedDb is null || _subscribedTable is null)
            return;

        // Re-run the query to get fresh data
        var freshResponse = Engine.Execute(queryText.Trim(), _subscribedDb);
        if (freshResponse.Operation == SproutOperation.Error || freshResponse.Data is null)
            return;

        var oldIds = CollectIds(_displayData);
        var newIds = CollectIds(freshResponse.Data);

        // New rows: in new but not in old
        foreach (var id in newIds)
        {
            if (!oldIds.Contains(id))
                _flashGreenIds.Add(id);
        }

        // Deleted rows: in old but not in new
        var deletedIds = new HashSet<ulong>();
        foreach (var id in oldIds)
        {
            if (!newIds.Contains(id))
                deletedIds.Add(id);
        }

        if (deletedIds.Count > 0)
        {
            // Keep old data visible during flash, mark deleted rows red
            foreach (var id in deletedIds)
                _flashRedIds.Add(id);

            // Store new data for later swap
            _pendingData = freshResponse.Data;
        }
        else
        {
            _displayData = freshResponse.Data;
            rowCount = freshResponse.Data.Count;
        }

        // Clear flash after 1.5 seconds
        _flashTimer?.Dispose();
        _flashTimer = new System.Threading.Timer(ClearFlash, null, 1500, Timeout.Infinite);

        InvokeAsync(StateHasChanged);
    }

    private void ClearFlash(object? state)
    {
        _flashGreenIds.Clear();
        _flashRedIds.Clear();

        // Swap to pending data if we were showing deleted rows
        if (_pendingData is not null)
        {
            _displayData = _pendingData;
            rowCount = _pendingData.Count;
            _pendingData = null;
        }

        InvokeAsync(StateHasChanged);
    }

    private static HashSet<ulong> CollectIds(List<Dictionary<string, object?>>? data)
    {
        var ids = new HashSet<ulong>();
        if (data is null) return ids;

        foreach (var row in data)
        {
            if (row.TryGetValue("_id", out var idVal) && idVal is ulong id)
                ids.Add(id);
        }
        return ids;
    }

    private static ulong? GetRowId(Dictionary<string, object?> row)
    {
        if (row.TryGetValue("_id", out var idVal) && idVal is ulong id)
            return id;
        return null;
    }

    private string GetRowFlashClass(ulong? rowId)
    {
        if (rowId is null) return "";
        if (_flashGreenIds.Contains(rowId.Value)) return "row-flash-green";
        if (_flashRedIds.Contains(rowId.Value)) return "row-flash-red";
        return "";
    }

    // --- Inline Editing ---

    private void StartEdit(ulong? rowId, string columnName, object? currentValue)
    {
        if (rowId is null) return;

        _editingRowId = rowId;
        _editingColumn = columnName;
        _editValue = FormatCell(currentValue);
        _editError = null;
        _shouldFocusEdit = true;
    }

    private void CancelEdit()
    {
        _editingRowId = null;
        _editingColumn = null;
        _editValue = string.Empty;
        _editError = null;
    }

    private void OnEditInput(ChangeEventArgs e)
    {
        _editValue = e.Value?.ToString() ?? string.Empty;
    }

    private void HandleEditKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            CancelEdit();
        }
        else if (e.Key == "Enter")
        {
            CommitEdit();
        }
    }

    private void CommitEdit()
    {
        if (_editingRowId is null || _editingColumn is null || _subscribedTable is null)
            return;

        var escapedValue = EscapeQueryValue(_editValue);
        var query = $"upsert {_subscribedTable} {{_id: {_editingRowId.Value}, {_editingColumn}: {escapedValue}}}";

        var response = Engine.Execute(query, selectedDatabase);
        if (response.Operation == SproutOperation.Error)
        {
            _editError = response.Errors?.FirstOrDefault()?.Message ?? "Unknown error";
            return;
        }

        CancelEdit();

        // Refresh data
        var freshResponse = Engine.Execute(queryText.Trim(), selectedDatabase);
        if (freshResponse.Data is not null)
        {
            _displayData = freshResponse.Data;
            rowCount = freshResponse.Data.Count;
        }
    }

    private static string EscapeQueryValue(string input)
    {
        if (string.IsNullOrEmpty(input) || input == "null")
            return "null";

        if (input is "true" or "false")
            return input;

        // Try parse as number
        if (long.TryParse(input, out _) || ulong.TryParse(input, out _) || double.TryParse(input, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out _))
            return input;

        // Quote as string, escaping inner quotes
        var escaped = input.Replace("\\", "\\\\").Replace("\"", "\\\"");
        return $"\"{escaped}\"";
    }

    // --- Helpers ---

    private static string? ExtractTableName(string query)
    {
        var parts = query.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        for (int i = 0; i < parts.Length; i++)
        {
            if (parts[i].Equals("from", StringComparison.OrdinalIgnoreCase) && i + 1 < parts.Length)
                return parts[i + 1];
        }
        if (parts.Length >= 2 && parts[0].Equals("get", StringComparison.OrdinalIgnoreCase)
            && !parts[1].Equals("from", StringComparison.OrdinalIgnoreCase))
        {
            return parts[1];
        }
        return null;
    }

    private static string GetCellClass(ColumnMeta col, object? value)
    {
        if (value is null) return "cell-null";
        if (col.Name == "_id") return "cell-id";

        return col.Type switch
        {
            "string" => "cell-string",
            "ulong" or "long" or "int" or "double" or "float" or "decimal" => "cell-number",
            "bool" => value is true ? "cell-bool-true" : "cell-bool-false",
            "datetime" => "cell-datetime",
            _ => value switch
            {
                string => "cell-string",
                bool b => b ? "cell-bool-true" : "cell-bool-false",
                DateTime => "cell-datetime",
                int or long or ulong or uint or float or double or decimal => "cell-number",
                _ => ""
            }
        };
    }

    private static string FormatCell(object? value)
    {
        return value switch
        {
            null => "null",
            bool b => b ? "true" : "false",
            DateTime dt => dt.ToString("yyyy-MM-dd HH:mm:ss"),
            _ => value.ToString() ?? ""
        };
    }

    private static string FormatElapsed(double ms)
    {
        if (ms < 1) return $"{ms:F2}ms";
        if (ms < 1000) return $"{ms:F1}ms";
        return $"{ms / 1000:F2}s";
    }

    private static string FormatBytes(int bytes)
    {
        if (bytes < 1024) return $"{bytes}B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1}KB";
        return $"{bytes / (1024.0 * 1024.0):F1}MB";
    }

    private static int EstimatePayload(SproutResponse response)
    {
        if (response.Data is not { Count: > 0 } data)
            return 0;

        int size = 0;
        foreach (var row in data)
        {
            foreach (var kvp in row)
            {
                size += kvp.Key.Length * 2;
                size += kvp.Value?.ToString()?.Length ?? 4;
            }
        }
        return size;
    }

    public void Dispose()
    {
        _tableSubscription?.Dispose();
        _flashTimer?.Dispose();
    }

    private sealed class ColumnMeta
    {
        public string Name { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
    }
}
