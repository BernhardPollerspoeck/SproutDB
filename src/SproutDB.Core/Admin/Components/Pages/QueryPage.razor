    private void LoadSavedQueries()
    {
        _savedQueries = null;

        if (string.IsNullOrEmpty(selectedDatabase))
            return;

        try
        {
            var response = Engine.ExecuteInternal("get _saved_queries", selectedDatabase);
            if (response.Operation == SproutOperation.Error || response.Data is null)
            {
                // Table might not exist yet — that's fine
                _savedQueries = [];
                return;
            }

            var list = new List<SavedQueryEntry>();
            foreach (var row in response.Data)
            {
                row.TryGetValue("name", out var nameVal);
                row.TryGetValue("query", out var queryVal);
                row.TryGetValue("pinned", out var pinnedVal);

                var name = nameVal?.ToString();
                var query = queryVal?.ToString();
                if (name is null || query is null) continue;

                list.Add(new SavedQueryEntry
                {
                    Name = name,
                    Query = query,
                    Pinned = pinnedVal is true,
                });
            }

            // Sort: pinned first, then alphabetical
            list.Sort((a, b) =>
            {
                if (a.Pinned != b.Pinned) return a.Pinned ? -1 : 1;
                return string.Compare(a.Name, b.Name, StringComparison.OrdinalIgnoreCase);
            });

            _savedQueries = list;
        }
        catch
        {
            _savedQueries = [];
        }
    }

    private void EnsureSavedQueriesTable()
    {
        if (string.IsNullOrEmpty(selectedDatabase)) return;

        // Try to create if not exists — ignore error if it already exists
        var response = Engine.ExecuteInternal("describe _saved_queries", selectedDatabase);
        if (response.Operation == SproutOperation.Error)
        {
            Engine.ExecuteInternal("create table _saved_queries (name string 200, query string 4000, pinned bool)", selectedDatabase);
        }
    }

