    private async Task OnBlobFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        const long maxSize = 10 * 1024 * 1024; // 10 MB
        if (file.Size > maxSize)
        {
            _runError = $"File too large ({file.Size / 1024.0 / 1024.0:F1} MB). Max 10 MB.";
            return;
        }

        using var ms = new MemoryStream();
        await file.OpenReadStream(maxSize).CopyToAsync(ms);
        var base64 = Convert.ToBase64String(ms.ToArray());

        // Insert base64 string at cursor position in textarea
        var newValue = await JS.InvokeAsync<string>("sproutAdmin.insertAtCursor", _editorWrapRef, $"'{base64}'");
        if (newValue is not null)
        {
            Tab.QueryText = newValue;
            _highlightedQuery = SyntaxHighlighter.Highlight(newValue);
        }
    }

