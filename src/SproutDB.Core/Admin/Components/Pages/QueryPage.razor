    // --- Export ---

    private async Task ExportCsv()
    {
        if (Tab.DisplayData is not { Count: > 0 } || Tab.Columns is not { Count: > 0 })
            return;

        var sb = new System.Text.StringBuilder();

        // Header
        sb.AppendJoin(',', Tab.Columns.Select(c => EscapeCsvField(c.Name)));
        sb.AppendLine();

        // Rows
        foreach (var row in Tab.DisplayData)
        {
            var first = true;
            foreach (var col in Tab.Columns)
            {
                if (!first) sb.Append(',');
                first = false;
                row.TryGetValue(col.Name, out var val);
                sb.Append(EscapeCsvField(FormatCellValue(val)));
            }
            sb.AppendLine();
        }

        await DownloadFile("export.csv", sb.ToString(), "text/csv");
    }

    private async Task ExportJson()
    {
        if (Tab.DisplayData is not { Count: > 0 })
            return;

        await DownloadFile("export.json", BuildJsonString(), "application/json");
