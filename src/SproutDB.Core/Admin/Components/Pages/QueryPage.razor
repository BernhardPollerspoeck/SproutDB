    private async Task OnInlineBlobSelected(InputFileChangeEventArgs e)
    {
        if (_editingRowId is null || _editingColumn is null || _subscribedTable is null)
        {
            CancelEdit();
            return;
        }

        var file = e.File;
        const long maxSize = 10 * 1024 * 1024; // 10 MB
        if (file.Size > maxSize)
        {
            _editError = $"File too large ({file.Size / 1024.0 / 1024.0:F1} MB). Max 10 MB.";
            return;
        }

        using var ms = new MemoryStream();
        await file.OpenReadStream(maxSize).CopyToAsync(ms);
        var base64 = Convert.ToBase64String(ms.ToArray());

        var rowId = _editingRowId.Value;
        var colName = _editingColumn;
        var table = _subscribedTable;

        var query = $"upsert {table} {{_id: {rowId}, {colName}: '{base64}'}}";
        var response = Engine.Execute(query, selectedDatabase);
        if (response.Operation == SproutOperation.Error)
        {
            _editError = response.Errors?.FirstOrDefault()?.Message ?? "Unknown error";
            return;
        }

        CancelEdit();

        // Refresh data
        var collapsed = CollapseQuery(QueryText);
        var freshResponse = Engine.Execute(collapsed, selectedDatabase);
        if (freshResponse.Data is not null)
        {
            Tab.DisplayData = freshResponse.Data;
            Tab.RowCount = freshResponse.Data.Count;
        }
    }

    private static string FormatBlobSize(string base64)
    {
        var bytes = base64.Length * 3 / 4;
        if (base64.EndsWith("==")) bytes -= 2;
        else if (base64.EndsWith("=")) bytes -= 1;

        if (bytes >= 1024 * 1024) return $"{bytes / (1024.0 * 1024.0):F1} MB";
        if (bytes >= 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes} B";
    }

    private static (string Mime, string Ext) DetectBlobType(string base64)
    {
        if (base64.StartsWith("/9j/")) return ("image/jpeg", ".jpg");
        if (base64.StartsWith("iVBOR")) return ("image/png", ".png");
        if (base64.StartsWith("R0lGO")) return ("image/gif", ".gif");
        if (base64.StartsWith("UklGR")) return ("image/webp", ".webp");
        if (base64.StartsWith("JVBER")) return ("application/pdf", ".pdf");
        if (base64.StartsWith("PD94b") || base64.StartsWith("PHN2Z")) return ("image/svg+xml", ".svg");
        return ("application/octet-stream", ".bin");
    }

    private async Task OpenBlobInTab(string base64)
    {
        var (mime, _) = DetectBlobType(base64);
        await JS.InvokeVoidAsync("sproutAdmin.openBlob", base64, mime);
    }

    private async Task DownloadBlob(string base64, string colName, object? rowId)
    {
        var (mime, ext) = DetectBlobType(base64);
        var filename = $"{colName}_{rowId}{ext}";
        await JS.InvokeVoidAsync("eval",
            $"(function(){{var a=document.createElement('a');a.href='data:{mime};base64,{base64}';a.download='{filename}';a.click();}})()");
    }

    private static string FormatElapsed(double ms)
    {
        if (ms < 1) return $"{ms:F2}ms";
        if (ms < 1000) return $"{ms:F1}ms";
        return $"{ms / 1000:F2}s";
    }

    private static string FormatBytes(int bytes)
    {
        if (bytes < 1024) return $"{bytes}B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1}KB";
        return $"{bytes / (1024.0 * 1024.0):F1}MB";
    }

    private static int EstimatePayload(SproutResponse response)
    {
        if (response.Data is not { Count: > 0 } data)
            return 0;

        int size = 0;
        foreach (var row in data)
        {
            foreach (var kvp in row)
            {
                size += kvp.Key.Length * 2;
                size += kvp.Value?.ToString()?.Length ?? 4;
            }
        }
        return size;
    }

    public void Dispose()
    {
        _tableSubscription?.Dispose();
        _statsFlashTimer?.Dispose();
        _flashTimer?.Dispose();
        _dotnetRef?.Dispose();
    }

    // Sort indicator
    private void ExtractSort(string query)
    {
        Tab.SortColumn = null;
        Tab.SortDesc = false;

        var tokens = query.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        for (int i = 0; i < tokens.Length - 1; i++)
        {
            if (tokens[i].Equals("order", StringComparison.OrdinalIgnoreCase)
                && i + 1 < tokens.Length && tokens[i + 1].Equals("by", StringComparison.OrdinalIgnoreCase)
                && i + 2 < tokens.Length)
            {
                Tab.SortColumn = tokens[i + 2];
                if (i + 3 < tokens.Length && tokens[i + 3].Equals("desc", StringComparison.OrdinalIgnoreCase))
                    Tab.SortDesc = true;
                return;
            }
            // SproutDB also supports "order col [desc]" without "by"
            if (tokens[i].Equals("order", StringComparison.OrdinalIgnoreCase)
                && !tokens[i + 1].Equals("by", StringComparison.OrdinalIgnoreCase))
            {
                Tab.SortColumn = tokens[i + 1];
                if (i + 2 < tokens.Length && tokens[i + 2].Equals("desc", StringComparison.OrdinalIgnoreCase))
                    Tab.SortDesc = true;
                return;
            }
        }
    }

    /// <summary>
    /// Collapses a formatted (multi-line) query into a single line.
    /// Line breaks are purely cosmetic — the editor always contains a single query.
    /// </summary>
    internal static string CollapseQuery(string text)
    {
        var parts = text.Split('\n');
        var sb = new System.Text.StringBuilder();

        foreach (var part in parts)
        {
            var trimmed = part.Trim();
            if (trimmed.Length == 0 || trimmed.StartsWith("##"))
                continue;

            if (sb.Length > 0)
                sb.Append(' ');
            sb.Append(trimmed);
        }

        return sb.ToString();
    }

