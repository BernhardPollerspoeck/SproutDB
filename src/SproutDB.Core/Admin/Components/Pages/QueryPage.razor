    private object BuildSchema(string dbName)
    {
        var tables = new List<string>();
        var columns = new Dictionary<string, List<string>>();

        var describeDb = Engine.Execute("describe", dbName);
        if (describeDb.Schema?.Tables is { } tableList)
        {
            tables.AddRange(tableList);
            foreach (var table in tableList)
            {
                var describeTable = Engine.Execute($"describe {table}", dbName);
                if (describeTable.Schema?.Columns is { } cols)
                {
                    var colNames = cols.Select(c => c.Name).ToList();
                    colNames.Add("_expiresat");
                    colNames.Add("_ttl");
                    columns[table] = colNames;
                }
            }
        }

        return new { tables, columns };
    }

