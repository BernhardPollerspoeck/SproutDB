@page "/sproutdb/admin"
@using SproutDB.Core.Admin
@implements IDisposable

<!-- Query Editor -->
<div class="query-section">
    <div class="query-toolbar">
        <select class="query-db-select" @bind="selectedDatabase" @bind:after="OnDatabaseChanged">
            <option value="">(select database)</option>
            @foreach (var db in databases)
            {
                <option value="@db.Name">@db.Name</option>
            }
        </select>
        <div class="query-toolbar-sep"></div>
        <button class="btn btn-ghost @(_showHistory ? "btn-ghost-active" : "")" style="font-size: 11px; padding: 3px 8px;" @onclick="ToggleHistory">History</button>
        <span class="auto-paged-badge">&#9889; auto-paged</span>
        <span class="query-hint"><kbd>Ctrl</kbd> + <kbd>Enter</kbd></span>
    </div>
    @if (_showHistory)
    {
        <div class="query-history-panel">
            <div class="history-filter-row">
                <input type="text" class="history-filter-input" placeholder="Filter history..." @bind="_historyFilter" @bind:event="oninput" />
            </div>
            @if (_filteredHistory is { Count: > 0 })
            {
                @foreach (var item in _filteredHistory)
                {
                    <div class="history-item" @onclick="() => ApplyHistoryItem(item)">
                        <span class="history-op @GetHistoryOpClass(item.Operation)">@item.Operation</span>
                        <span class="history-query">@item.Query</span>
                        <span class="history-db">@item.Database</span>
                        <span class="history-time">@FormatRelativeTime(item.Timestamp)</span>
                    </div>
                }
            }
            else
            {
                <div style="padding: 12px; font-size: 11.5px; color: var(--text-3); font-style: italic;">No history</div>
            }
        </div>
    }
    <div class="query-editor-wrap" @ref="_editorWrapRef">
        <pre class="query-editor-highlight" aria-hidden="true">@_highlightedQuery </pre>
        <textarea class="query-editor"
                  spellcheck="false"
                  placeholder="Enter SproutDB query..."
                  @bind="QueryText"
                  @bind:event="oninput"
                  @onkeydown="HandleKeyDown"></textarea>
    </div>
    <div class="query-actions">
        <button class="btn btn-primary" @onclick="RunQuery">&#9654; Run</button>
        <button class="btn btn-ghost">Format</button>
        @if (_runError is not null)
        {
            <span style="color: var(--red); font-size: 12px; font-weight: 500;">@_runError</span>
        }
        else if (lastResponse is not null)
        {
            <div class="query-stats @(_statsFlash ? "stats-flash" : "")">
                <span class="stat-ok">&#10003;</span>
                <span><span class="stat-value">@FormatElapsed(elapsedMs)</span> <span class="stat-label">time</span></span>
                <span><span class="stat-value">@rowCount</span> <span class="stat-label">rows</span></span>
                <span><span class="stat-value">@FormatBytes(payloadBytes)</span> <span class="stat-label">size</span></span>
            </div>
        }
    </div>
</div>

<!-- Results / Error -->
<div class="results-section">
    @if (lastResponse is not null && lastResponse.Operation == SproutOperation.Error)
    {
        <!-- Error display -->
        <div class="error-panel">
            <div class="error-panel-header">Query Error</div>
            @if (lastResponse.Errors is { Count: > 0 } errors)
            {
                @foreach (var err in errors)
                {
                    <div class="error-item">
                        <span class="error-code">@err.Code</span>
                        <span class="error-message">@err.Message</span>
                    </div>
                    @if (err.Code == "UNKNOWN_COLUMN" && err.Position >= 0 && err.Length > 0)
                    {
                        var availableCols = GetAvailableColumnsForError();
                        if (availableCols.Count > 0)
                        {
                            var capturedErr = err;
                            <div class="error-fix-row">
                                <span class="error-fix-label">Available:</span>
                                @foreach (var col in availableCols)
                                {
                                    var capturedCol = col;
                                    <button class="error-fix-badge" @onclick="() => FixColumnInQuery(capturedErr, capturedCol)">@col</button>
                                }
                            </div>
                        }
                    }
                }
            }
            @if (!string.IsNullOrEmpty(lastResponse.AnnotatedQuery))
            {
                <pre class="error-annotated">@lastResponse.AnnotatedQuery</pre>
            }
        </div>
    }
    else if (_displayData is { Count: > 0 } data)
    {
        <!-- Results table -->
        <div class="results-tabs">
            <button class="results-tab @(_activeTab == "results" ? "active" : "")" @onclick='() => _activeTab = "results"'>Results <span class="tab-count">@data.Count</span></button>
            <button class="results-tab @(_activeTab == "json" ? "active" : "")" @onclick="SwitchToJson">JSON</button>
        </div>
        @if (_activeTab == "json")
        {
            <div class="json-panel">
                <div class="json-toolbar">
                    @if (_jsonCopied)
                    {
                        <span class="json-copied">Copied</span>
                    }
                    <button class="btn btn-ghost" style="font-size: 11px; padding: 3px 10px;" @onclick="CopyJson">Copy</button>
                </div>
                <pre class="json-content">@_jsonDisplay</pre>
            </div>
        }
        else
        {
        <div class="results-table-wrap">
            <table class="results-table">
                <thead>
                    <tr>
                        @foreach (var col in columns)
                        {
                            var isSorted = _sortColumn is not null
                                && string.Equals(col.Name, _sortColumn, StringComparison.OrdinalIgnoreCase);
                            <th>
                                <div class="th-content">
                                    @col.Name
                                    @if (isSorted)
                                    {
                                        <span class="th-sort">@(_sortDesc ? "\u25BC" : "\u25B2")</span>
                                    }
                                    <span class="th-type">@col.Type</span>
                                </div>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in data)
                    {
                        var rowId = GetRowId(row);
                        <tr @key="rowId" class="@GetRowFlashClass(rowId)">
                            @foreach (var col in columns)
                            {
                                row.TryGetValue(col.Name, out var cellValue);
                                @if (_editingRowId is not null && _editingRowId == rowId && _editingColumn == col.Name)
                                {
                                    <td class="@GetCellClass(col, cellValue) cell-editing">
                                        <input @ref="_editInputRef"
                                               class="cell-edit-input"
                                               type="text"
                                               @bind="_editValue"
                                               @bind:event="oninput"
                                               @onkeyup="HandleEditKeyUp"
                                               @onblur="CommitEdit" />
                                        @if (_editError is not null)
                                        {
                                            <div class="cell-edit-error">@_editError</div>
                                        }
                                    </td>
                                }
                                else
                                {
                                    @if (_canEdit && col.Name != "_id" && _hasIdColumn)
                                    {
                                        <td class="@GetCellClass(col, cellValue) cell-editable"
                                            @ondblclick="() => StartEdit(rowId, col.Name, cellValue)">
                                            @FormatCell(cellValue)
                                            <span class="cell-edit-icon" @onclick="() => StartEdit(rowId, col.Name, cellValue)" @onclick:stopPropagation="true">&#9998;</span>
                                        </td>
                                    }
                                    else
                                    {
                                        <td class="@GetCellClass(col, cellValue)">
                                            @FormatCell(cellValue)
                                        </td>
                                    }
                                }
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        }
    }
    else if (lastResponse is not null)
    {
        <!-- Non-data response (e.g. upsert, delete, describe) -->
        <div class="results-tabs">
            <button class="results-tab active">Result</button>
        </div>
        <div class="results-table-wrap">
            <div style="padding: 16px;">
                <div class="admin-status success" style="font-size: 14px; padding: 12px 16px;">
                    <span style="font-weight: 600;">@lastResponse.Operation</span> completed — @lastResponse.Affected row(s) affected
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- No query run yet -->
        <div class="results-tabs">
            <button class="results-tab active">Results</button>
        </div>
        <div class="results-table-wrap">
            <div class="placeholder-page">
                <div class="placeholder-title" style="font-size: 14px;">Run a query to see results</div>
                <div class="placeholder-subtitle">Use the editor above or click a table in the sidebar</div>
            </div>
        </div>
    }
</div>

@code {
    [Inject]
    private SproutEngine Engine { get; set; } = default!;

    [Inject]
    private IJSRuntime JS { get; set; } = default!;

    [SupplyParameterFromQuery(Name = "db")]
    private string? DbParam { get; set; }

    [SupplyParameterFromQuery(Name = "q")]
    private string? QParam { get; set; }

    private IReadOnlyList<ISproutDatabase> databases => Engine.GetDatabases();
    private string selectedDatabase = string.Empty;
    private string _QueryText = string.Empty;
    private MarkupString _highlightedQuery;

    private string QueryText
    {
        get => _QueryText;
        set
        {
            _QueryText = value;
            _highlightedQuery = SyntaxHighlighter.Highlight(value);
        }
    }

    private SproutResponse? lastResponse;
    private double elapsedMs;
    private string _activeTab = "results";
    private MarkupString _jsonDisplay;
    private bool _jsonCopied;
    private int rowCount;
    private int payloadBytes;
    private List<ColumnMeta> columns = new();

    private bool autoExecuted;
    private bool _statsFlash;
    private System.Threading.Timer? _statsFlashTimer;

    // Live-update state
    private IDisposable? _tableSubscription;
    private string? _subscribedDb;
    private string? _subscribedTable;
    private List<Dictionary<string, object?>>? _displayData;
    private readonly HashSet<ulong> _flashGreenIds = new();
    private readonly HashSet<ulong> _flashRedIds = new();
    private System.Threading.Timer? _flashTimer;
    private List<Dictionary<string, object?>>? _pendingData;
    private bool _canEdit;
    private bool _hasIdColumn;

    // Editor overlay
    private ElementReference _editorWrapRef;
    private bool _editorInitialized;

    // Autocomplete
    private DotNetObjectReference<QueryPage>? _dotnetRef;
    private string _lastSchemaDb = string.Empty;

    // History panel
    private bool _showHistory;
    private static readonly List<HistoryItem> _historyItems = new();
    private const int MaxHistoryItems = 50;
    private string _historyFilter = string.Empty;

    private List<HistoryItem> _filteredHistory =>
        string.IsNullOrEmpty(_historyFilter)
            ? _historyItems
            : _historyItems.Where(h =>
                h.Query.Contains(_historyFilter, StringComparison.OrdinalIgnoreCase) ||
                h.Operation.Contains(_historyFilter, StringComparison.OrdinalIgnoreCase) ||
                h.Database.Contains(_historyFilter, StringComparison.OrdinalIgnoreCase))
                .ToList();

    // Inline editing state
    private ElementReference _editInputRef;
    private bool _shouldFocusEdit;
    private ulong? _editingRowId;
    private string? _editingColumn;
    private string _editValue = string.Empty;
    private string? _editError;

    protected override void OnInitialized()
    {
        if (databases.Count == 1)
        {
            selectedDatabase = databases[0].Name;
        }
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(DbParam))
        {
            selectedDatabase = DbParam;
        }

        if (!string.IsNullOrEmpty(QParam) && !autoExecuted)
        {
            QueryText = QParam;
            autoExecuted = true;
            RunQuery();
        }

        if (_editorInitialized && selectedDatabase != _lastSchemaDb)
        {
            _ = PushSchemaAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_editorInitialized)
        {
            _editorInitialized = true;
            await JS.InvokeVoidAsync("sproutAdmin.initEditor", _editorWrapRef);
            _dotnetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("sproutAdmin.initAutocomplete", _editorWrapRef, _dotnetRef);
            await JS.InvokeVoidAsync("eval",
                "document.addEventListener('keydown',function(e){if(e.altKey&&e.key==='l'){e.preventDefault();document.querySelector('.query-editor')?.focus();}})");
            await PushSchemaAsync();
        }

        if (_shouldFocusEdit)
        {
            _shouldFocusEdit = false;
            try { await _editInputRef.FocusAsync(); } catch { }
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e is { CtrlKey: true, Key: "Enter" })
        {
            RunQuery();
        }
    }

    private string? _runError;

    private void RunQuery()
    {
        _runError = null;
        _appliedFixes.Clear();

        if (string.IsNullOrWhiteSpace(selectedDatabase))
        {
            _runError = "Select a database first";
            return;
        }

        if (string.IsNullOrWhiteSpace(QueryText))
            return;

        // Clear editing state
        CancelEdit();

        // Split into individual queries (one per line, skip empty/comment-only lines)
        var lines = QueryText.Split('\n')
            .Select(l => l.Trim())
            .Where(l => l.Length > 0 && !l.StartsWith("##"))
            .ToList();

        if (lines.Count == 0)
            return;

        var sw = System.Diagnostics.Stopwatch.StartNew();

        SproutResponse? lastDataResponse = null;
        string? lastDataQuery = null;
        lastResponse = null;
        int totalRows = 0;
        int totalPayload = 0;

        foreach (var line in lines)
        {
            var response = Engine.Execute(line, selectedDatabase);
            lastResponse = response;

            if (response.Operation != SproutOperation.Error)
            {
                RecordHistory(line, selectedDatabase, response.Operation.ToString().ToUpperInvariant());
            }

            if (response.Operation == SproutOperation.Error)
                break;

            totalRows += response.Data?.Count ?? response.Affected;
            totalPayload += EstimatePayload(response);

            if (response.Data is { Count: > 0 })
            {
                lastDataResponse = response;
                lastDataQuery = line;
            }
        }

        sw.Stop();

        // Show the last data-returning result, or the very last result
        if (lastDataResponse is not null)
        {
            lastResponse = lastDataResponse;
            RebuildColumns(lastDataResponse, lastDataQuery ?? lines[^1]);
            _displayData = lastDataResponse.Data;
        }
        else if (lastResponse is not null)
        {
            RebuildColumns(lastResponse, lines[^1]);
            _displayData = lastResponse.Data;
        }

        elapsedMs = sw.Elapsed.TotalMilliseconds;
        rowCount = totalRows;
        payloadBytes = totalPayload;
        ExtractSort(lines[^1]);

        if (_activeTab == "json" && _displayData is { Count: > 0 })
            _jsonDisplay = HighlightJson(BuildJsonString());

        // Flash the stats bar to signal execution
        _statsFlash = true;
        _statsFlashTimer?.Dispose();
        _statsFlashTimer = new System.Threading.Timer(_ =>
        {
            _statsFlash = false;
            InvokeAsync(StateHasChanged);
        }, null, 1200, Timeout.Infinite);

        // Set up live subscription for Get queries
        SetupLiveSubscription();
    }

    private void RebuildColumns(SproutResponse response, string query)
    {
        columns.Clear();
        _hasIdColumn = false;

        if (response.Data is not { Count: > 0 } data)
            return;

        var firstRow = data[0];
        var tableName = ExtractTableName(query);
        Dictionary<string, ColumnInfo>? schemaMap = null;

        if (tableName is not null)
        {
            var describeResponse = Engine.Execute($"describe {tableName}", selectedDatabase);
            if (describeResponse.Schema?.Columns is { } cols)
            {
                schemaMap = new Dictionary<string, ColumnInfo>(StringComparer.OrdinalIgnoreCase);
                foreach (var c in cols)
                {
                    schemaMap[c.Name] = c;
                }
            }
        }

        foreach (var key in firstRow.Keys)
        {
            if (key == "_id") _hasIdColumn = true;

            var type = "unknown";
            if (schemaMap is not null && schemaMap.TryGetValue(key, out var colInfo))
            {
                type = colInfo.Type;
            }
            else
            {
                var val = firstRow[key];
                type = val switch
                {
                    null => "null",
                    string => "string",
                    bool => "bool",
                    DateTime => "datetime",
                    int or long or ulong or uint => "long",
                    float or double or decimal => "double",
                    _ => val.GetType().Name.ToLowerInvariant()
                };
            }
            columns.Add(new ColumnMeta { Name = key, Type = type });
        }
    }

    private void SetupLiveSubscription()
    {
        // Dispose previous subscription
        _tableSubscription?.Dispose();
        _tableSubscription = null;
        _subscribedDb = null;
        _subscribedTable = null;
        _canEdit = false;
        _flashGreenIds.Clear();
        _flashRedIds.Clear();

        if (lastResponse?.Operation != SproutOperation.Get || lastResponse.Data is not { Count: > 0 })
            return;

        var tableName = ExtractTableName(QueryText);
        if (tableName is null)
            return;

        _subscribedDb = selectedDatabase;
        _subscribedTable = tableName;
        _canEdit = _hasIdColumn;

        _tableSubscription = Engine.ChangeNotifier.Subscribe(selectedDatabase, tableName, OnTableChanged);
    }

    private void OnTableChanged(SproutResponse _)
    {
        // Skip live updates while inline editing is active
        if (_editingRowId is not null)
            return;

        if (_subscribedDb is null || _subscribedTable is null)
            return;

        // Re-run the query to get fresh data
        var freshResponse = Engine.Execute(QueryText.Trim(), _subscribedDb);
        if (freshResponse.Operation == SproutOperation.Error || freshResponse.Data is null)
            return;

        var oldIds = CollectIds(_displayData);
        var newIds = CollectIds(freshResponse.Data);

        // New rows: in new but not in old
        foreach (var id in newIds)
        {
            if (!oldIds.Contains(id))
                _flashGreenIds.Add(id);
        }

        // Deleted rows: in old but not in new
        var deletedIds = new HashSet<ulong>();
        foreach (var id in oldIds)
        {
            if (!newIds.Contains(id))
                deletedIds.Add(id);
        }

        if (deletedIds.Count > 0)
        {
            // Keep old data visible during flash, mark deleted rows red
            foreach (var id in deletedIds)
                _flashRedIds.Add(id);

            // Store new data for later swap
            _pendingData = freshResponse.Data;
        }
        else
        {
            _displayData = freshResponse.Data;
            rowCount = freshResponse.Data.Count;
        }

        // Clear flash after 1.5 seconds
        _flashTimer?.Dispose();
        _flashTimer = new System.Threading.Timer(ClearFlash, null, 1500, Timeout.Infinite);

        InvokeAsync(StateHasChanged);
    }

    private void ClearFlash(object? state)
    {
        _flashGreenIds.Clear();
        _flashRedIds.Clear();

        // Swap to pending data if we were showing deleted rows
        if (_pendingData is not null)
        {
            _displayData = _pendingData;
            rowCount = _pendingData.Count;
            _pendingData = null;
        }

        InvokeAsync(StateHasChanged);
    }

    private static HashSet<ulong> CollectIds(List<Dictionary<string, object?>>? data)
    {
        var ids = new HashSet<ulong>();
        if (data is null) return ids;

        foreach (var row in data)
        {
            if (row.TryGetValue("_id", out var idVal) && idVal is ulong id)
                ids.Add(id);
        }
        return ids;
    }

    private static ulong? GetRowId(Dictionary<string, object?> row)
    {
        if (row.TryGetValue("_id", out var idVal) && idVal is ulong id)
            return id;
        return null;
    }

    private string GetRowFlashClass(ulong? rowId)
    {
        if (rowId is null) return "";
        if (_flashGreenIds.Contains(rowId.Value)) return "row-flash-green";
        if (_flashRedIds.Contains(rowId.Value)) return "row-flash-red";
        return "";
    }

    // --- Inline Editing ---

    private void StartEdit(ulong? rowId, string columnName, object? currentValue)
    {
        if (rowId is null) return;

        _editingRowId = rowId;
        _editingColumn = columnName;
        _editValue = FormatCell(currentValue);
        _editError = null;
        _shouldFocusEdit = true;
    }

    private void CancelEdit()
    {
        _editingRowId = null;
        _editingColumn = null;
        _editValue = string.Empty;
        _editError = null;
    }

    private void HandleEditKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            CancelEdit();
        }
        else if (e.Key == "Enter")
        {
            CommitEdit();
        }
    }

    private void CommitEdit()
    {
        if (_editingRowId is null || _editingColumn is null || _subscribedTable is null)
            return;

        var escapedValue = EscapeQueryValue(_editValue);
        var query = $"upsert {_subscribedTable} {{_id: {_editingRowId.Value}, {_editingColumn}: {escapedValue}}}";

        var response = Engine.Execute(query, selectedDatabase);
        if (response.Operation == SproutOperation.Error)
        {
            _editError = response.Errors?.FirstOrDefault()?.Message ?? "Unknown error";
            return;
        }

        CancelEdit();

        // Refresh data
        var freshResponse = Engine.Execute(QueryText.Trim(), selectedDatabase);
        if (freshResponse.Data is not null)
        {
            _displayData = freshResponse.Data;
            rowCount = freshResponse.Data.Count;
        }
    }

    private static string EscapeQueryValue(string input)
    {
        if (string.IsNullOrEmpty(input) || input == "null")
            return "null";

        if (input is "true" or "false")
            return input;

        // Try parse as number
        if (long.TryParse(input, out _) || ulong.TryParse(input, out _) || double.TryParse(input, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out _))
            return input;

        // Quote as string, escaping inner single quotes
        var escaped = input.Replace("'", "\\'");
        return $"'{escaped}'";
    }

    private async Task OnDatabaseChanged()
    {
        if (_editorInitialized)
        {
            await PushSchemaAsync();
        }
    }

    // --- Autocomplete ---

    [JSInvokable]
    public void OnAutoCompleteInput(string value)
    {
        _QueryText = value;
        _highlightedQuery = SyntaxHighlighter.Highlight(value);
        StateHasChanged();
    }

    private async Task PushSchemaAsync()
    {
        if (string.IsNullOrEmpty(selectedDatabase))
        {
            _lastSchemaDb = string.Empty;
            return;
        }

        _lastSchemaDb = selectedDatabase;
        var schema = BuildSchema(selectedDatabase);
        await JS.InvokeVoidAsync("sproutAdmin.updateSchema", schema);
    }

    private object BuildSchema(string dbName)
    {
        var tables = new List<string>();
        var columns = new Dictionary<string, List<string>>();

        var describeDb = Engine.Execute("describe", dbName);
        if (describeDb.Schema?.Tables is { } tableList)
        {
            tables.AddRange(tableList);
            foreach (var table in tableList)
            {
                var describeTable = Engine.Execute($"describe {table}", dbName);
                if (describeTable.Schema?.Columns is { } cols)
                {
                    columns[table] = cols.Select(c => c.Name).ToList();
                }
            }
        }

        return new { tables, columns };
    }

    // --- JSON tab ---

    private string BuildJsonString()
    {
        if (_displayData is null or { Count: 0 })
            return "[]";

        return System.Text.Json.JsonSerializer.Serialize(_displayData, new System.Text.Json.JsonSerializerOptions
        {
            WriteIndented = true,
        });
    }

    private void SwitchToJson()
    {
        _activeTab = "json";
        _jsonDisplay = HighlightJson(BuildJsonString());
    }

    private static MarkupString HighlightJson(string json)
    {
        var sb = new System.Text.StringBuilder(json.Length * 2);
        var i = 0;
        while (i < json.Length)
        {
            var ch = json[i];

            if (ch == '"')
            {
                // Find end of string
                var end = i + 1;
                while (end < json.Length && json[end] != '"')
                {
                    if (json[end] == '\\') end++; // skip escaped char
                    end++;
                }
                if (end < json.Length) end++; // include closing quote
                var str = System.Net.WebUtility.HtmlEncode(json.Substring(i, end - i));

                // Check if this is a key (followed by ':')
                var afterStr = end;
                while (afterStr < json.Length && json[afterStr] == ' ') afterStr++;
                if (afterStr < json.Length && json[afterStr] == ':')
                    sb.Append($"<span class=\"json-key\">{str}</span>");
                else
                    sb.Append($"<span class=\"json-string\">{str}</span>");
                i = end;
                continue;
            }
            else if (char.IsDigit(ch) || (ch == '-' && i + 1 < json.Length && char.IsDigit(json[i + 1])))
            {
                var end = i + 1;
                while (end < json.Length && (char.IsDigit(json[end]) || json[end] == '.' || json[end] == 'E' || json[end] == 'e'))
                    end++;
                sb.Append($"<span class=\"json-number\">{json.Substring(i, end - i)}</span>");
                i = end;
                continue;
            }
            else if (i + 4 <= json.Length && json.AsSpan(i, 4).SequenceEqual("true"))
            {
                sb.Append("<span class=\"json-bool\">true</span>");
                i += 4;
                continue;
            }
            else if (i + 5 <= json.Length && json.AsSpan(i, 5).SequenceEqual("false"))
            {
                sb.Append("<span class=\"json-bool\">false</span>");
                i += 5;
                continue;
            }
            else if (i + 4 <= json.Length && json.AsSpan(i, 4).SequenceEqual("null"))
            {
                sb.Append("<span class=\"json-null\">null</span>");
                i += 4;
                continue;
            }
            else
            {
                sb.Append(ch);
            }
            i++;
        }
        return new MarkupString(sb.ToString());
    }

    private async Task CopyJson()
    {
        var json = BuildJsonString();
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", json);
        _jsonCopied = true;
        StateHasChanged();
        await Task.Delay(1500);
        _jsonCopied = false;
        StateHasChanged();
    }

    // --- Column fix suggestions ---

    private List<string> GetAvailableColumnsForError()
    {
        if (string.IsNullOrEmpty(selectedDatabase) || string.IsNullOrWhiteSpace(QueryText))
            return [];

        // Extract table name from query (second token, e.g. "get users ...")
        var tokens = QueryText.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (tokens.Length < 2)
            return [];

        var tableName = tokens[1];
        var describeResponse = Engine.Execute($"describe {tableName}", selectedDatabase);
        if (describeResponse.Schema?.Columns is not { } cols)
            return [];

        return cols.Select(c => c.Name).ToList();
    }

    private readonly List<(int OriginalPosition, int Delta)> _appliedFixes = [];

    private void FixColumnInQuery(SproutError err, string correctColumn)
    {
        if (string.IsNullOrEmpty(QueryText) || err.Position < 0 || err.Length <= 0)
            return;

        // Calculate offset from all fixes that were applied before this error's position
        var offset = _appliedFixes
            .Where(f => f.OriginalPosition < err.Position)
            .Sum(f => f.Delta);

        var adjustedPos = err.Position + offset;
        if (adjustedPos < 0 || adjustedPos + err.Length > QueryText.Length)
            return;

        QueryText = string.Concat(
            QueryText.AsSpan(0, adjustedPos),
            correctColumn,
            QueryText.AsSpan(adjustedPos + err.Length));

        _appliedFixes.Add((err.Position, correctColumn.Length - err.Length));
    }

    // --- History ---

    private void ToggleHistory()
    {
        _showHistory = !_showHistory;
        if (_showHistory)
            LoadHistory();
    }

    private void LoadHistory()
    {
        _historyFilter = string.Empty;
    }

    private static void RecordHistory(string query, string database, string operation)
    {
        _historyItems.Insert(0, new HistoryItem
        {
            Query = query,
            Database = database,
            Operation = operation,
            Timestamp = DateTime.Now,
        });
        if (_historyItems.Count > MaxHistoryItems)
            _historyItems.RemoveAt(_historyItems.Count - 1);
    }

    private void ApplyHistoryItem(HistoryItem item)
    {
        QueryText = item.Query;
        if (!string.IsNullOrEmpty(item.Database))
            selectedDatabase = item.Database;
        _showHistory = false;
    }

    private static string GetHistoryOpClass(string op)
    {
        return op.ToUpperInvariant() switch
        {
            "GET" => "op-get",
            "UPSERT" => "op-upsert",
            "DELETE" => "op-delete",
            "CREATE" or "CREATETABLE" or "CREATEDATABASE" => "op-create",
            _ => "op-other"
        };
    }

    private static string FormatRelativeTime(DateTime timestamp)
    {
        if (timestamp == DateTime.MinValue) return "";
        var elapsed = DateTime.Now - timestamp;
        if (elapsed.TotalSeconds < 60) return $"{Math.Max(1, (int)elapsed.TotalSeconds)}s";
        if (elapsed.TotalMinutes < 60) return $"{(int)elapsed.TotalMinutes}m";
        if (elapsed.TotalHours < 24) return $"{(int)elapsed.TotalHours}h";
        return $"{(int)elapsed.TotalDays}d";
    }

    // --- Helpers ---

    private static string? ExtractTableName(string query)
    {
        var parts = query.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        for (int i = 0; i < parts.Length; i++)
        {
            if (parts[i].Equals("from", StringComparison.OrdinalIgnoreCase) && i + 1 < parts.Length)
                return parts[i + 1];
        }
        if (parts.Length >= 2 && parts[0].Equals("get", StringComparison.OrdinalIgnoreCase)
            && !parts[1].Equals("from", StringComparison.OrdinalIgnoreCase))
        {
            return parts[1];
        }
        return null;
    }

    private static string GetCellClass(ColumnMeta col, object? value)
    {
        if (value is null) return "cell-null";
        if (col.Name == "_id") return "cell-id";

        return col.Type switch
        {
            "string" => "cell-string",
            "ulong" or "long" or "int" or "double" or "float" or "decimal" => "cell-number",
            "bool" => value is true ? "cell-bool-true" : "cell-bool-false",
            "datetime" => "cell-datetime",
            _ => value switch
            {
                string => "cell-string",
                bool b => b ? "cell-bool-true" : "cell-bool-false",
                DateTime => "cell-datetime",
                int or long or ulong or uint or float or double or decimal => "cell-number",
                _ => ""
            }
        };
    }

    private static string FormatCell(object? value)
    {
        return value switch
        {
            null => "null",
            bool b => b ? "true" : "false",
            DateTime dt => dt.ToString("yyyy-MM-dd HH:mm:ss"),
            _ => value.ToString() ?? ""
        };
    }

    private static string FormatElapsed(double ms)
    {
        if (ms < 1) return $"{ms:F2}ms";
        if (ms < 1000) return $"{ms:F1}ms";
        return $"{ms / 1000:F2}s";
    }

    private static string FormatBytes(int bytes)
    {
        if (bytes < 1024) return $"{bytes}B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1}KB";
        return $"{bytes / (1024.0 * 1024.0):F1}MB";
    }

    private static int EstimatePayload(SproutResponse response)
    {
        if (response.Data is not { Count: > 0 } data)
            return 0;

        int size = 0;
        foreach (var row in data)
        {
            foreach (var kvp in row)
            {
                size += kvp.Key.Length * 2;
                size += kvp.Value?.ToString()?.Length ?? 4;
            }
        }
        return size;
    }

    public void Dispose()
    {
        _tableSubscription?.Dispose();
        _statsFlashTimer?.Dispose();
        _flashTimer?.Dispose();
        _dotnetRef?.Dispose();
    }

    // Sort indicator
    private string? _sortColumn;
    private bool _sortDesc;

    private void ExtractSort(string query)
    {
        _sortColumn = null;
        _sortDesc = false;

        var tokens = query.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        for (int i = 0; i < tokens.Length - 1; i++)
        {
            if (tokens[i].Equals("order", StringComparison.OrdinalIgnoreCase)
                && i + 1 < tokens.Length && tokens[i + 1].Equals("by", StringComparison.OrdinalIgnoreCase)
                && i + 2 < tokens.Length)
            {
                _sortColumn = tokens[i + 2];
                if (i + 3 < tokens.Length && tokens[i + 3].Equals("desc", StringComparison.OrdinalIgnoreCase))
                    _sortDesc = true;
                return;
            }
            // SproutDB also supports "order col [desc]" without "by"
            if (tokens[i].Equals("order", StringComparison.OrdinalIgnoreCase)
                && !tokens[i + 1].Equals("by", StringComparison.OrdinalIgnoreCase))
            {
                _sortColumn = tokens[i + 1];
                if (i + 2 < tokens.Length && tokens[i + 2].Equals("desc", StringComparison.OrdinalIgnoreCase))
                    _sortDesc = true;
                return;
            }
        }
    }

    private sealed class ColumnMeta
    {
        public string Name { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
    }

    private sealed class HistoryItem
    {
        public string Query { get; set; } = string.Empty;
        public string Database { get; set; } = string.Empty;
        public string Operation { get; set; } = string.Empty;
        public DateTime Timestamp { get; set; }
    }
